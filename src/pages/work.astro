---
import { getCollection } from 'astro:content';
import Layout from '../layouts/Layout.astro';
import Footer from '../components/Footer.astro';

// Portfolio projects from content collection
const portfolioProjects = (await getCollection('portfolio')).sort((a, b) => a.data.order - b.data.order);

const allProjects = portfolioProjects.map(project => ({
  title: project.data.title,
  company: project.data.company,
  category: project.data.category.toUpperCase(),
  services: project.data.services,
  image: project.data.heroImage,
  slug: project.slug,
  year: project.data.year,
  outcomeShort: project.data.outcomeShort
}));

const categories = ['ALL', ...new Set(allProjects.map(project => project.category))];
---

<Layout 
  title="Work | Lumina7 - Portfolio & Case Studies"
  description="Brand identity, websites, print, and signage, built for South African businesses."
>
  <!-- Proof-led hero -->
  <section class="relative pt-16 pb-14 px-4 sm:px-6 lg:px-8 border-b border-primary crop-marks">
    <span class="crop-b"></span>
    <div class="max-w-7xl mx-auto">
      <div class="max-w-5xl">
        <p class="label-mono text-tertiary mb-5">Selected work · {allProjects.length.toString().padStart(2, '0')} projects</p>
        <h1 class="text-heading-1 text-primary mb-5">Work that <span class="hl-spot">proves the point.</span></h1>
        <p class="text-body-lg text-secondary max-w-2xl">Brand identity, websites, print, and signage, built to help South African businesses look credible and move forward.</p>
      </div>
    </div>
  </section>

  <!-- Project filters -->
  <section class="px-4 sm:px-6 lg:px-8 border-b border-primary">
    <div class="max-w-7xl mx-auto">
      <div class="flex gap-2 py-4 overflow-x-auto scrollbar-hide" aria-label="Filter projects">
        {categories.map(category => (
          <button 
            class="filter-btn label-mono min-h-[44px] px-4 py-2 text-tertiary border border-primary rounded whitespace-nowrap hover:text-primary hover:border-current focus-visible:outline-none"
            data-filter={category.toLowerCase()}
            type="button"
          >
            {category}
          </button>
        ))}
      </div>
    </div>
  </section>

  <!-- Work specimens -->
  <section class="py-14 sm:py-20 px-4 sm:px-6 lg:px-8">
    <div class="max-w-7xl mx-auto">
      <div id="projects-grid" class="grid md:grid-cols-2 lg:grid-cols-3 gap-7">
        {allProjects.map(project => (
          <article class="project-item" data-category={project.category.toLowerCase()}>
            <a href={`/work/${project.slug}`} class="work-specimen group relative block h-full bg-white dark:bg-[#1D1A16] p-3.5 crop-marks transition-all duration-300 hover:-translate-y-1 hover:shadow-[0_12px_32px_rgba(22,20,15,0.12)] focus-visible:outline-none">
              <span class="crop-b"></span>
              <div class="overflow-hidden mb-4 bg-secondary">
                  <img
                    src={project.image}
                    alt={project.title}
                    class="w-full aspect-[4/3] object-cover group-hover:scale-[1.03] transition-transform duration-500"
                    loading="lazy"
                  />
              </div>

              <div class="px-1">
                <div class="flex items-center justify-between gap-4 mb-3">
                  <span class="label-mono text-tertiary">{project.category}</span>
                  <span class="label-mono text-tertiary tabular-nums">{project.year}</span>
                </div>
                <h2 class="font-display text-xl text-primary mb-2" style="font-weight: 660;">{project.company || project.title}</h2>
                <p class="text-body-sm text-secondary mb-5 min-h-[2.75rem]">{project.title}</p>

                <dl class="border-t border-primary label-mono">
                  <div class="flex justify-between gap-4 py-2 border-b border-primary">
                    <dt class="text-tertiary">Scope</dt>
                    <dd class="m-0 text-right text-primary">{project.services.slice(0, 2).join(' + ')}</dd>
                  </div>
                  {project.outcomeShort && (
                    <div class="flex justify-between gap-4 py-2 border-b border-primary items-center">
                      <dt class="text-tertiary">Outcome</dt>
                      <dd class="m-0 chip-spot text-right">{project.outcomeShort}</dd>
                    </div>
                  )}
                </dl>
              </div>
            </a>
          </article>
        ))}
      </div>
    </div>
  </section>

  <Footer />
</Layout>


<script>
  function initPortfolioFilters() {
    const filterButtons = document.querySelectorAll('.filter-btn');
    const projectItems = document.querySelectorAll('.project-item');
    if (!filterButtons.length || !projectItems.length) return;
    
    // Set initial active state
    filterButtons.forEach((button, index) => {
      button.setAttribute('aria-pressed', index === 0 ? 'true' : 'false');
    });
    
    filterButtons.forEach((button) => {
      if ((button as HTMLElement).dataset.filterBound === 'true') return;
      (button as HTMLElement).dataset.filterBound = 'true';
      button.addEventListener('click', () => {
        const filter = button.getAttribute('data-filter');
        
        // Update active button
        filterButtons.forEach((btn) => {
          btn.setAttribute('aria-pressed', 'false');
        });
        button.setAttribute('aria-pressed', 'true');
        
        // Filter projects
        projectItems.forEach((item) => {
          const category = item.getAttribute('data-category');
          const el = item as HTMLElement;
          if (filter === 'all' || category === filter) {
            el.style.display = 'block';
          } else {
            el.style.display = 'none';
          }
        });
      });
    });
  }

  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', initPortfolioFilters, { once: true });
  } else {
    initPortfolioFilters();
  }
  document.addEventListener('astro:page-load', initPortfolioFilters);
</script>

<style>
  .filter-btn[aria-pressed='true'] {
    background: var(--color-spot);
    border-color: var(--color-spot);
    color: var(--color-spot-ink);
    font-weight: 600;
  }
</style>
