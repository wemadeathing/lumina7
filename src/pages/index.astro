  <script>
    // Services horizontal scroll functionality
    const servicesContainer = document.getElementById('services-container') as HTMLElement | null;
    const scrollLeftBtn = document.getElementById('scroll-left') as HTMLButtonElement | null;
    const scrollRightBtn = document.getElementById('scroll-right') as HTMLButtonElement | null;
    
    if (servicesContainer && scrollLeftBtn && scrollRightBtn) {
      const scrollAmount = 400;
      
      // Update button states based on scroll position
      function updateButtonStates(): void {
        if (!servicesContainer || !scrollLeftBtn || !scrollRightBtn) return;
        const { scrollLeft, scrollWidth, clientWidth } = servicesContainer;
        scrollLeftBtn.disabled = scrollLeft <= 0;
        scrollRightBtn.disabled = scrollLeft + clientWidth >= scrollWidth - 10;
      }
      
      // Initial state
      updateButtonStates();
      
      // Scroll left
      scrollLeftBtn.addEventListener('click', (): void => {
        if (!servicesContainer) return;
        servicesContainer.scrollBy({
          left: -scrollAmount,
          behavior: 'smooth'
        });
        setTimeout(updateButtonStates, 300);
      });
      
      // Scroll right
      scrollRightBtn.addEventListener('click', (): void => {
        if (!servicesContainer) return;
        servicesContainer.scrollBy({
          left: scrollAmount,
          behavior: 'smooth'
        });
        setTimeout(updateButtonStates, 300);
      });
      
      // Update on scroll
      servicesContainer.addEventListener('scroll', updateButtonStates);
      
      // Update on resize
      window.addEventListener('resize', updateButtonStates);
    }

    // Video Play/Pause Toggle
    const video = document.getElementById('hero-video') as HTMLVideoElement | null;
    const toggleBtn = document.getElementById('video-control-btn');
    const playIcon = document.getElementById('play-icon');
    const pauseIcon = document.getElementById('pause-icon');

    if (video && toggleBtn && playIcon && pauseIcon) {
      toggleBtn.addEventListener('click', () => {
        if (video.paused) {
          video.play();
          playIcon.classList.add('hidden');
          pauseIcon.classList.remove('hidden');
          toggleBtn.setAttribute('aria-label', 'Pause video');
        } else {
          video.pause();
          pauseIcon.classList.add('hidden');
          playIcon.classList.remove('hidden');
          toggleBtn.setAttribute('aria-label', 'Play video');
        }
      });
    }
  </script>

