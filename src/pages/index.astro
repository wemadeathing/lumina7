---
import Layout from '../layouts/Layout.astro';
import Footer from '../components/Footer.astro';
import WhatsAppButton from '../components/WhatsAppButton.astro';
import CTA from '../components/CTA.astro';
import FAQ from '../components/FAQ.astro';
import Testimonials from '../components/Testimonials.astro';
import ProcessTimeline from '../components/ProcessTimeline.astro';
import { getCollection } from 'astro:content';

const allProjects = await getCollection('portfolio');
const featuredProjects = allProjects
  .filter(project => project.data.featured)
  .sort((a, b) => a.data.order - b.data.order)
  .slice(0, 3);

const services = [
  { title: 'Brand Identity', tagline: 'Logo, colour, typography and brand guidelines. From R5,000', link: '/services/brand-identity' },
  { title: 'Print & Marketing Materials', tagline: 'Flyers, brochures, business cards, menus. From R800', link: '/services/print' },
  { title: 'Signage & Installations', tagline: 'Shopfront signage, banners, vehicle branding. From R1,500', link: '/services/signage' },
  { title: 'Website Design & Development', tagline: 'Professional websites that look great and load fast. From R8,000', link: '/services/websites' },
  { title: 'Social Media & Digital Assets', tagline: 'Profile graphics, post templates, digital ads. From R1,200', link: '/services/print' }
];

const processSteps = [
  { label: 'Day 1', title: 'Tell us what you need.', description: "We'll ask the right questions and come back with a fixed quote within 24 hours." },
  { label: 'Day 14', title: 'Review and refine.', description: "You approve the direction while we design and build with structured feedback rounds." },
  { label: 'Day 21', title: 'Launch with confidence.', description: "Final files, live site, and handover complete. Ready for your next phase of growth." }
];

const testimonials = [
  { quote: "Lumina7 delivered our full rebrand in under three weeks. The quality was exceptional and Nasif really understood what we were trying to achieve.", name: "Client Name", business: "Business Name" },
  { quote: "We needed a website fast before a big corporate event. They delivered on time and it looked better than agencies charging three times as much.", name: "Client Name", business: "Business Name" },
  { quote: "Professional, communicative and genuinely good at what they do. I've already referred two other businesses.", name: "Client Name", business: "Business Name" }
];

const clientLogos = [
  { src: '/assets/logos/clients/Arabica Logo Dark.png', alt: 'Arabica Coffee' },
  { src: '/assets/logos/clients/ECOS Logo dark.png', alt: 'ECOS' },
  { src: '/assets/logos/clients/HP Logo dark.png', alt: 'HP' },
  { src: '/assets/logos/clients/Straptec-logo.png', alt: 'Straptec' },
  { src: '/assets/logos/clients/YP_Logo_Dark.png', alt: 'YP' }
];

const faqItems = [
  { number: "01", question: "How much does a website cost?", answer: "Our websites start from R8,000 for a professional 5-page brochure site. Custom or e-commerce sites are quoted based on scope. We always provide a fixed quote before starting. No surprises." },
  { number: "02", question: "How much does a logo or brand identity cost?", answer: "Logo and brand identity packages start from R5,000 and include logo files, colour palette, typography, and basic brand guidelines. Full brand identity systems with comprehensive guidelines start from R12,000." },
  { number: "03", question: "How long does a project take?", answer: "Most projects are completed within 2–4 working weeks from the day we receive your deposit and brief. Timeline depends on scope and how quickly you can review and approve work. We'll agree on a specific timeline before we start." },
  { number: "04", question: "Do I own my website and logo after the project?", answer: "Yes. All intellectual property transfers to you in full once final payment is received. You own everything: files, code, domain, and hosting credentials." },
  { number: "05", question: "Can you handle print production as well as design?", answer: "Yes. We design and manage print production for flyers, menus, signage, business cards, brochures, and large format. We work with trusted SA print suppliers and can manage the full process on your behalf." },
  { number: "06", question: "Do you work with small businesses and startups?", answer: "Yes, most of our clients are owner-run businesses and growing SMEs. We work with businesses at all stages, from brand new startups to established companies refreshing their identity." }
];
---

<Layout 
  title="Lumina7 | Brand Identity, Websites & Print Design | Cape Town"
  description="Cape Town design studio specialising in brand identity, websites, print and signage for South African businesses. Fast turnaround. Fixed quotes. B-BBEE Level 1."
  useGlobalTopGradient={true}
>
  <!-- Hero Section -->
  <section class="pt-24 pb-20 px-4 sm:px-6 lg:px-8">
    <div class="max-w-7xl mx-auto">
      <div class="max-w-4xl">
        <h1 class="text-[2.75rem] sm:text-[3.3rem] md:text-[4.95rem] font-medium text-gray-900 dark:text-gray-100 mb-8 leading-[0.95] mt-8 tracking-tight transition-colors duration-300">
          <span class="block">We design brands and websites for South African businesses.</span>
        </h1>
        <p class="text-body-lg text-primary max-w-3xl">
          Branding, print, signage, and websites, delivered in weeks, not months.
        </p>
        <div class="mt-8">
          <WhatsAppButton label="WhatsApp Us" size="lg" prefillText="Hi%2C%20I%27d%20like%20to%20enquire%20about%20your%20design%20services" />
        </div>
      </div>
    </div>
  </section>

  <!-- Client Logo Bar -->
  <section class="py-16 px-4 sm:px-6 lg:px-8 bg-white dark:bg-[#0a0a0a] transition-colors duration-300">
    <div class="max-w-4xl mx-auto overflow-hidden">
      <p class="text-caption text-tertiary mb-8 text-center">Trusted by South African businesses</p>
      <div class="flex flex-wrap gap-8 sm:gap-12 md:gap-16 justify-center items-center py-4">
        {clientLogos.map((logo, i) => (
          <img
            src={logo.src}
            alt={logo.alt}
            class={`object-contain opacity-60 grayscale hover:opacity-100 hover:grayscale-0 transition-all duration-300 flex-shrink-0 ${i === 0 ? 'h-[2.2rem]' : 'h-8'}`}
            loading="lazy"
          />
        ))}
      </div>
    </div>
  </section>

  <!-- Services Section - Becklyn style numbered list -->
  <section class="py-20 px-4 sm:px-6 lg:px-8 bg-white dark:bg-[#0a0a0a] transition-colors duration-300 ">
    <div class="max-w-7xl mx-auto">
      <div class="pb-10">
        <h2 class="text-heading-2 text-primary mb-4">How we help</h2>
        <p class="text-body text-secondary max-w-2xl">From first impression to final install, we handle every design touchpoint.</p>
      </div>
      <div class="space-y-1 mt-12">
        {services.map((service, index) => (
          <a href={service.link} class="group grid grid-cols-[2rem_1fr_auto] md:grid-cols-[2rem_minmax(0,1fr)_minmax(0,1.4fr)_1rem] gap-x-4 md:gap-x-8 gap-y-2 items-baseline py-6 border-b border-gray-200 dark:border-neutral-800 last:border-b-0 hover:bg-gray-50 dark:hover:bg-neutral-900/50 transition-colors duration-300 -mx-4 px-4 rounded-[4px]">
            <span class="text-sm font-medium text-gray-400 dark:text-neutral-500 tabular-nums">{(index + 1).toString().padStart(2, '0')}</span>
            <span class="text-lg md:text-xl font-medium text-gray-900 dark:text-white group-hover:text-gray-600 dark:group-hover:text-neutral-300 transition-colors">{service.title}</span>
            <p class="col-start-2 col-span-2 md:col-start-3 md:col-span-1 text-body text-secondary md:text-right">{service.tagline}</p>
            <span class="col-start-3 md:col-start-4 row-span-2 md:row-span-1 self-center justify-self-end text-gray-400 dark:text-neutral-500 group-hover:translate-x-1 transition-transform">→</span>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- Cases Section - Becklyn style: first full-width, rest 2-col grid -->
  <section class="py-20 bg-white dark:bg-[#0a0a0a] transition-colors duration-300 ">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="mb-16 flex items-end justify-between">
        <h2 class="text-heading-2 md:text-heading-1 text-primary">Recent work</h2>
        <a href="/work" class="text-sm font-medium text-gray-500 dark:text-neutral-400 hover:text-gray-900 dark:hover:text-white transition-colors">View all projects</a>
      </div>
      <div class="flex flex-col md:flex-row md:flex-wrap gap-6 md:gap-8">
        {featuredProjects.map((project, index) => (
          <a href={`/work/${project.slug}`} class={`group block rounded-2xl overflow-hidden bg-gray-200 dark:bg-neutral-800 ${index === 0 ? 'w-full' : 'w-full md:w-[calc(50%-1rem)]'}`}>
            <div class="relative aspect-square md:aspect-video overflow-hidden">
              <img src={project.data.heroImage} alt={project.data.title} class="w-full h-full object-cover group-hover:scale-[1.03] transition-transform duration-500" loading="lazy" />
              <div class="hidden md:flex absolute inset-0 p-8 lg:p-12 flex-col justify-between bg-gradient-to-t from-black/70 via-black/20 to-transparent opacity-0 group-hover:opacity-100 transition-opacity duration-300">
                <div class="flex flex-wrap gap-2">
                  {project.data.services.slice(0, 3).map((service) => (
                    <span class="inline-flex items-center px-4 py-2 rounded-full text-xs font-medium bg-white/95 dark:bg-neutral-100 text-gray-900 min-h-[2.25rem]">{service}</span>
                  ))}
                </div>
                <div>
                  <h3 class="text-2xl md:text-3xl font-medium text-white mb-2 tracking-tight" style="letter-spacing: -0.05rem;">{project.data.company}</h3>
                  <p class="text-white/90 text-sm md:text-base leading-relaxed max-w-xl">{project.data.description}</p>
                </div>
              </div>
            </div>
            <div class="md:hidden p-6 bg-gray-100 dark:bg-neutral-900">
              <div class="flex flex-wrap gap-2 mb-3">
                {project.data.services.slice(0, 3).map((service) => (
                  <span class="inline-flex items-center px-4 py-2 rounded-full text-xs font-medium bg-white dark:bg-neutral-800 text-gray-900 dark:text-white">{service}</span>
                ))}
              </div>
              <h3 class="text-xl font-medium text-gray-900 dark:text-white mb-2">{project.data.company}</h3>
              <p class="text-sm text-gray-600 dark:text-neutral-400 leading-relaxed">{project.data.description}</p>
            </div>
          </a>
        ))}
      </div>
    </div>
  </section>

  <ProcessTimeline
    eyebrow="Let's get started"
    title="Simple process. Fast results."
    subtitle="Most clients go from first conversation to final delivery in 2–4 weeks."
    steps={processSteps}
  />

  <!-- Testimonials hidden for now -->
  <!-- <Testimonials testimonials={testimonials} /> -->

  <FAQ faqItems={faqItems} heading="Common questions" />

  <CTA />

  <Footer />
</Layout>
