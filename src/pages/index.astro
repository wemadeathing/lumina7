---
import Layout from '../layouts/Layout.astro';
import Footer from '../components/Footer.astro';
import CTA from '../components/CTA.astro';
import FAQ from '../components/FAQ.astro';
import { getCollection } from 'astro:content';

// Get portfolio projects
const allProjects = await getCollection('portfolio');
const featuredProjects = allProjects
  .filter(project => project.data.featured)
  .sort((a, b) => a.data.order - b.data.order)
  .slice(0, 3);

const services = [
  {
    title: "Brand Sprint",
    tagline: "Your complete brand identity in 2 weeks"
  },
  {
    title: "Website Sprint",
    tagline: "AI-optimized websites that work everywhere"
  },
  {
    title: "Print & Signage Sprint",
    tagline: "Print, signage, and marketing materials in 2 weeks"
  }
];

const faqItems = [
  {
    number: "01",
    question: "What makes Lumina7 different from other design studios?",
    answer: "We combine innovation and speed through AI-augmented workflows. This enables more exploration, breakthrough solutions, and rapid execution—without compromising thoughtful execution or quality. Like our name suggests (Lumina = light), we deliver at the speed of light while maintaining the highest standards."
  },
  {
    number: "02",
    question: "How do AI-augmented workflows benefit my project?", 
    answer: "AI-augmented design processes enable more creative exploration, faster iteration, and better solutions. We use cutting-edge tools to enhance our capabilities, allowing us to deliver innovative outcomes in shorter timeframes while maintaining focused execution and quality."
  },
  {
    number: "03",
    question: "Do you work with clients in different industries?",
    answer: "Yes, we work across various industries including technology, fintech, healthcare, e-commerce, and professional services. Our diverse experience allows us to bring fresh perspectives and proven approaches to each project."
  },
  {
    number: "04",
    question: "What is your approach to branding and design?",
    answer: "We focus on business outcomes first. Every decision drives tangible results—attracting customers and fueling growth. We combine expert thinking with innovative workflows to create brand experiences that work for your business goals."
  },
  {
    number: "05",
    question: "Do you work with startups and established businesses?",
    answer: "Absolutely. We partner with ambitious businesses at all stages, from early-stage startups to established enterprises. Our rapid, innovation-powered approach is especially valuable for businesses that need to compete and grow quickly."
  },
  {
    number: "06",
    question: "How do you ensure quality with rapid delivery?",
    answer: "Speed doesn't mean rushed work. We move fast through AI-augmented innovation and efficient processes, but every project receives focused attention and expert refinement. Our approach enables rapid iteration while maintaining professional quality throughout."
  }
];
---

<Layout 
  title="Lumina7 | Innovation-Powered Design at the Speed of Light"
  description="AI-augmented design studio delivering breakthrough brand experiences faster. We combine strategic thinking with innovative workflows to help ambitious businesses compete and grow."
>
  <!-- Hero Section -->
  <section class="pt-24 pb-20 px-4 sm:px-6 lg:px-8 bg-primary">
    <div class="max-w-7xl mx-auto">
      <div class="max-w-4xl">
        <h1 
          class="text-[2.75rem] sm:text-[3.3rem] md:text-[4.95rem] font-medium text-gray-900 dark:text-gray-100 mb-8 leading-[0.95] mt-8 tracking-tight transition-colors duration-300"
        >
          <span class="block">We design brands and websites, <span class="italic">fast.</span></span>
        </h1>
        
        <p class="text-body-lg text-primary max-w-3xl">
          Premium Brand and Website Sprints delivered in 2 weeks. Optimized for humans and AI agents. South African studio serving ambitious businesses.
        </p>
        <div class="mt-8 text-caption text-tertiary">
          [ Scroll down ]
        </div>
      </div>
    </div>
  </section>

  <!-- Services Section - Becklyn style numbered list -->
  <section class="py-24 px-6 lg:px-8 bg-white dark:bg-black transition-colors duration-300 border-t border-gray-200 dark:border-neutral-900">
    <div class="max-w-4xl mx-auto">
      <h2 class="text-2xl md:text-3xl font-medium text-gray-900 dark:text-white mb-4">
        Our Services & Solutions
      </h2>
      <div class="space-y-1 mt-12">
        {services.map((service, index) => (
          <a 
            href="/services" 
            class="group flex items-baseline gap-4 md:gap-8 py-6 border-b border-gray-200 dark:border-neutral-800 last:border-b-0 hover:bg-gray-50 dark:hover:bg-neutral-900/50 transition-colors duration-200 -mx-4 px-4 rounded-[4px]"
          >
            <span class="text-sm font-medium text-gray-400 dark:text-neutral-500 tabular-nums min-w-[2rem]">
              {(index + 1).toString().padStart(2, '0')}
            </span>
            <div class="flex-1 min-w-0">
              <span class="text-lg md:text-xl font-medium text-gray-900 dark:text-white group-hover:text-gray-600 dark:group-hover:text-neutral-300 transition-colors">
                {service.title}
              </span>
              <span class="text-gray-500 dark:text-neutral-400 ml-2">
                {service.tagline}
              </span>
            </div>
            <span class="text-gray-400 dark:text-neutral-500 group-hover:translate-x-1 transition-transform">→</span>
          </a>
        ))}
      </div>
      <p class="mt-16 text-gray-600 dark:text-neutral-400 leading-relaxed max-w-2xl">
        As a design studio, we combine strategic thinking with a keen sense for outstanding design and innovative workflows. We believe that brand and digital products are powerful when they clearly address real needs – functionally, visually and thoughtfully detailed.
      </p>
    </div>
  </section>

  <!-- Cases Section - Becklyn style: first full-width, rest 2-col grid, text overlay on desktop -->
  <section class="py-24 bg-white dark:bg-black transition-colors duration-300 border-t border-gray-200 dark:border-neutral-900">
    <div class="max-w-7xl mx-auto px-6 lg:px-8">
      <div class="mb-16 flex items-end justify-between">
        <h2 class="text-2xl md:text-3xl font-medium text-gray-900 dark:text-white tracking-tight" style="letter-spacing: -0.05rem;">
          Cases – Insights & Results
        </h2>
        <a href="/work" class="text-sm font-medium text-gray-500 dark:text-neutral-400 hover:text-gray-900 dark:hover:text-white transition-colors">
          All cases →
        </a>
      </div>

      <!-- Becklyn layout: first card full-width, rest 2-col grid -->
      <div class="flex flex-col md:flex-row md:flex-wrap gap-6 md:gap-8">
        {featuredProjects.map((project, index) => (
          <a 
            href={`/work/${project.slug}`}
            class={`group block rounded-2xl overflow-hidden bg-gray-200 dark:bg-neutral-800 ${
              index === 0 ? 'w-full' : 'w-full md:w-[calc(50%-1rem)]'
            }`}
          >
            <div class="relative aspect-square md:aspect-video overflow-hidden">
              <img 
                src={project.data.heroImage} 
                alt={project.data.title}
                class="w-full h-full object-cover group-hover:scale-[1.03] transition-transform duration-700"
              />
              <!-- Desktop: text overlay on image - visible on hover only -->
              <div class="hidden md:flex absolute inset-0 p-8 lg:p-12 flex-col justify-between bg-gradient-to-t from-black/70 via-black/20 to-transparent opacity-0 group-hover:opacity-100 transition-opacity duration-300">
                <div class="flex flex-wrap gap-2">
                  {project.data.services.slice(0, 3).map((service) => (
                    <span class="inline-flex items-center px-4 py-2 rounded-full text-xs font-medium bg-white/95 dark:bg-neutral-100 text-gray-900 min-h-[2.25rem]">
                      {service}
                    </span>
                  ))}
                </div>
                <div>
                  <h3 class="text-2xl md:text-3xl font-medium text-white mb-2 tracking-tight" style="letter-spacing: -0.05rem;">
                    {project.data.company}
                  </h3>
                  <p class="text-white/90 text-sm md:text-base leading-relaxed max-w-xl">
                    {project.data.description}
                  </p>
                </div>
              </div>
            </div>
            <!-- Mobile: content below image -->
            <div class="md:hidden p-6 bg-gray-100 dark:bg-neutral-900">
              <div class="flex flex-wrap gap-2 mb-3">
                {project.data.services.slice(0, 3).map((service) => (
                  <span class="inline-flex items-center px-4 py-2 rounded-full text-xs font-medium bg-white dark:bg-neutral-800 text-gray-900 dark:text-white">
                    {service}
                  </span>
                ))}
              </div>
              <h3 class="text-xl font-medium text-gray-900 dark:text-white mb-2">
                {project.data.company}
              </h3>
              <p class="text-sm text-gray-600 dark:text-neutral-400 leading-relaxed">
                {project.data.description}
              </p>
            </div>
          </a>
        ))}
      </div>
    </div>
  </section>


  <FAQ faqItems={faqItems} />

  <CTA />

  <Footer />
</Layout>
