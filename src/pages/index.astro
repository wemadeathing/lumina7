---
import Layout from '../layouts/Layout.astro';
import Footer from '../components/Footer.astro';
import WhatsAppButton from '../components/WhatsAppButton.astro';
import CTA from '../components/CTA.astro';
import FAQ from '../components/FAQ.astro';
import ProcessTimeline from '../components/ProcessTimeline.astro';
import { getCollection } from 'astro:content';

const allProjects = await getCollection('portfolio');
const featuredProjects = allProjects
  .filter(project => project.data.featured)
  .sort((a, b) => a.data.order - b.data.order)
  .slice(0, 3);

const rateCard = [
  { name: 'Brand identity', desc: 'Logo, colour, typography and brand guidelines.', price: 'from R5,000', link: '/services/brand-identity' },
  { name: 'Print & marketing', desc: 'Flyers, brochures, business cards, menus.', price: 'from R800', link: '/services/print' },
  { name: 'Signage & installations', desc: 'Shopfront signage, banners, vehicle branding.', price: 'from R1,500', link: '/services/signage' },
  { name: 'Websites', desc: 'Fast, credible websites that convert visits into enquiries.', price: 'from R8,000', link: '/services/websites' },
  { name: 'Social & digital assets', desc: 'Profile graphics, post templates, digital ads.', price: 'from R1,200', link: '/services' }
];

const processSteps = [
  { label: 'Day 1', title: 'Tell us what you need.', description: "We'll ask the right questions and come back with a fixed quote within 24 hours." },
  { label: 'Day 14', title: 'Review and refine.', description: "You approve the direction while we design and build with structured feedback rounds." },
  { label: 'Day 21', title: 'Launch with confidence.', description: "Final files, live site, and handover complete. Ready for your next phase of growth." }
];

const clientLogos = [
  { src: '/assets/logos/clients/Arabica Logo Dark.png', alt: 'Arabica Coffee' },
  { src: '/assets/logos/clients/ECOS Logo dark.png', alt: 'ECOS' },
  { src: '/assets/logos/clients/HP Logo dark.png', alt: 'HP' },
  { src: '/assets/logos/clients/Straptec-logo.png', alt: 'Straptec' },
  { src: '/assets/logos/clients/YP_Logo_Dark.png', alt: 'YourPractiz' }
];

const faqItems = [
  { number: "01", question: "How much does a website cost?", answer: "Our websites start from R8,000 for a professional 5-page brochure site. Custom or e-commerce sites are quoted based on scope. We always provide a fixed quote before starting. No surprises." },
  { number: "02", question: "How much does a logo or brand identity cost?", answer: "Logo and brand identity packages start from R5,000 and include logo files, colour palette, typography, and basic brand guidelines. Full brand identity systems with comprehensive guidelines start from R12,000." },
  { number: "03", question: "How long does a project take?", answer: "Most projects are completed within 2–4 working weeks from the day we receive your deposit and brief. Timeline depends on scope and how quickly you can review and approve work. We'll agree on a specific timeline before we start." },
  { number: "04", question: "Do I own my website and logo after the project?", answer: "Yes. All intellectual property transfers to you in full once final payment is received. You own everything: files, code, domain, and hosting credentials." },
  { number: "05", question: "Can you handle print production as well as design?", answer: "Yes. We design and manage print production for flyers, menus, signage, business cards, brochures, and large format. We work with trusted SA print suppliers and can manage the full process on your behalf." },
  { number: "06", question: "Do you work with small businesses and startups?", answer: "Yes, most of our clients are owner-run businesses and growing SMEs. We work with businesses at all stages, from brand new startups to established companies refreshing their identity." }
];
---

<Layout
  title="Lumina7 | Brand Identity, Websites & Print Design | Cape Town"
  description="Cape Town design studio specialising in brand identity, websites, print and signage for South African businesses. Fast turnaround. Fixed quotes. B-BBEE Level 1."
>
  <!-- Job ticket strip -->
  <div class="border-b border-primary">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-2.5 flex flex-wrap items-center justify-between gap-x-8 gap-y-1">
      <span class="label-mono text-tertiary">Cape Town design studio</span>
      <span class="label-mono text-tertiary hidden md:inline">Brand &middot; Print &middot; Signage &middot; Web</span>
      <span class="label-mono text-tertiary hidden sm:inline">Fixed quotes &middot; 2&ndash;4 week delivery</span>
      <span class="chip-spot label-mono">B-BBEE Level 1</span>
    </div>
  </div>

  <!-- Hero -->
  <section class="relative pt-20 pb-20 px-4 sm:px-6 lg:px-8 border-b border-primary crop-marks">
    <span class="crop-b"></span>
    <div class="max-w-7xl mx-auto">
      <div class="max-w-5xl">
        <h1 class="font-display text-[2.75rem] sm:text-[3.3rem] md:text-[4.6rem] leading-[1.02] tracking-[-0.03em] text-primary mb-8 mt-6" style="font-weight: 760; text-wrap: balance;">
          We design brands and websites for <span class="hl-spot">South African businesses.</span>
        </h1>
        <p class="text-body-lg text-secondary max-w-3xl mb-9">
          Branding, print, signage, and websites, delivered in weeks, not months.
        </p>
        <div class="flex flex-wrap items-center gap-6 mb-10">
          <WhatsAppButton label="WhatsApp us" size="lg" prefillText="Hi%2C%20I%27d%20like%20to%20enquire%20about%20your%20design%20services" eventSource="homepage_hero" />
          <a href="/contact" class="text-sm font-medium text-secondary hover:text-primary underline underline-offset-4 transition-colors duration-300" data-event="contact_form_link_click" data-event-source="homepage_hero">or send a message</a>
        </div>
        <div class="flex flex-wrap gap-x-8 gap-y-2">
          <span class="label-mono text-tertiary tick-spot">Fixed quote within 24 hours</span>
          <span class="label-mono text-tertiary tick-spot">Delivery in 2&ndash;4 weeks</span>
          <span class="label-mono text-tertiary tick-spot">You own everything we make</span>
        </div>
      </div>
    </div>
  </section>

  <!-- Client marquee -->
  <section class="border-b border-primary py-8 overflow-hidden" aria-label="Trusted by South African businesses">
    <div class="marquee" role="presentation">
      <div class="marquee-inner">
        {clientLogos.map((logo) => (
          <img src={logo.src} alt={logo.alt} class="h-8 object-contain opacity-60 grayscale dark:invert dark:opacity-70" loading="lazy" />
        ))}
        <span class="label-mono text-tertiary whitespace-nowrap">Trusted by South African businesses</span>
      </div>
      <div class="marquee-inner" aria-hidden="true">
        {clientLogos.map((logo) => (
          <img src={logo.src} alt="" class="h-8 object-contain opacity-60 grayscale dark:invert dark:opacity-70" loading="lazy" />
        ))}
        <span class="label-mono text-tertiary whitespace-nowrap">Trusted by South African businesses</span>
      </div>
    </div>
  </section>

  <!-- Rate card -->
  <section class="py-20 px-4 sm:px-6 lg:px-8 border-b border-primary">
    <div class="max-w-7xl mx-auto">
      <div class="flex flex-wrap items-baseline justify-between gap-x-10 gap-y-3 mb-12">
        <h2 class="text-heading-2 md:text-heading-1 text-primary">The rate card.</h2>
        <p class="label-mono text-tertiary">Fixed quotes &middot; No surprises &middot; Prices in ZAR</p>
      </div>
      <div>
        {rateCard.map((service, index) => (
          <a href={service.link} class="rate-row group grid grid-cols-[2.4rem_minmax(0,1fr)_auto] md:grid-cols-[3rem_minmax(0,1.1fr)_minmax(0,1.6fr)_auto_2rem] gap-x-5 md:gap-x-8 gap-y-1 items-baseline py-6 px-3 -mx-3 border-t border-primary last:border-b transition-colors duration-300 hover:bg-white dark:hover:bg-neutral-900">
            <span class="label-mono text-tertiary">{(index + 1).toString().padStart(2, '0')}</span>
            <span class="font-display text-lg md:text-xl text-primary" style="font-weight: 620;">{service.name}</span>
            <span class="col-start-2 md:col-start-3 col-span-2 md:col-span-1 text-body-sm text-secondary">{service.desc}</span>
            <span class="label-mono text-primary tabular-nums whitespace-nowrap row-start-1 col-start-3 md:col-start-4 justify-self-end">{service.price}</span>
            <span class="hidden md:inline text-tertiary group-hover:text-spot group-hover:translate-x-1 transition-all duration-300 justify-self-end" aria-hidden="true">&rarr;</span>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- Work specimens -->
  <section class="py-20 px-4 sm:px-6 lg:px-8 border-b border-primary">
    <div class="max-w-7xl mx-auto">
      <div class="flex flex-wrap items-baseline justify-between gap-x-10 gap-y-3 mb-12">
        <h2 class="text-heading-2 md:text-heading-1 text-primary">Recent work, pulled as proofs.</h2>
        <a href="/work" class="label-mono text-tertiary hover:text-primary transition-colors duration-300">Full portfolio &rarr;</a>
      </div>
      <div class="grid md:grid-cols-3 gap-7">
        {featuredProjects.map((project) => (
          <a href={`/work/${project.slug}`} class="specimen group relative block bg-white dark:bg-neutral-900 p-3.5 crop-marks transition-all duration-300 hover:-translate-y-1 hover:shadow-[0_12px_32px_rgba(22,20,15,0.12)]">
            <span class="crop-b"></span>
            <div class="overflow-hidden mb-4">
              <img
                src={project.data.heroImage}
                alt={`${project.data.company} — ${project.data.description}`}
                class="w-full aspect-[4/3] object-cover group-hover:scale-[1.03] transition-transform duration-500"
                loading="lazy"
              />
            </div>
            <h3 class="font-display text-lg text-primary px-1 mb-3" style="font-weight: 660;">{project.data.company}</h3>
            <dl class="mx-1 mb-1 border-t border-primary label-mono">
              <div class="flex justify-between gap-4 py-1.5 border-b border-primary">
                <dt class="text-tertiary">Scope</dt>
                <dd class="m-0 text-right text-primary">{project.data.services.slice(0, 2).join(' + ')}</dd>
              </div>
              <div class="flex justify-between gap-4 py-1.5 border-b border-primary">
                <dt class="text-tertiary">Year</dt>
                <dd class="m-0 text-right text-primary tabular-nums">{project.data.year}</dd>
              </div>
              {project.data.outcomeShort && (
                <div class="flex justify-between gap-4 py-1.5 border-b border-primary items-center">
                  <dt class="text-tertiary">Outcome</dt>
                  <dd class="m-0 chip-spot">{project.data.outcomeShort}</dd>
                </div>
              )}
            </dl>
          </a>
        ))}
      </div>
    </div>
  </section>

  <ProcessTimeline
    eyebrow="Let's get started"
    title="Simple process. Fast results."
    subtitle="Most clients go from first conversation to final delivery in 2–4 weeks."
    steps={processSteps}
  />

  <FAQ faqItems={faqItems} heading="Common questions" />

  <CTA />

  <Footer />
</Layout>

<style>
  /* proof-row tick squares */
  .tick-spot::before {
    content: '';
    display: inline-block;
    width: 8px;
    height: 8px;
    background: var(--color-spot);
    margin-right: 10px;
  }

  /* client logo marquee */
  .marquee {
    display: flex;
    width: max-content;
  }
  .marquee-inner {
    display: flex;
    align-items: center;
    gap: 56px;
    padding-right: 56px;
  }
  @media (prefers-reduced-motion: no-preference) {
    .marquee {
      animation: marquee-scroll 38s linear infinite;
    }
  }
  @keyframes marquee-scroll {
    from { transform: translateX(0); }
    to { transform: translateX(-50%); }
  }
  @media (prefers-reduced-motion: reduce) {
    .marquee { flex-wrap: wrap; width: 100%; justify-content: center; }
    .marquee-inner[aria-hidden="true"] { display: none; }
    .marquee-inner { flex-wrap: wrap; justify-content: center; padding: 0 24px; }
  }
</style>
