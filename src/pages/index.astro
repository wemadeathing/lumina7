---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import CTA from '../components/CTA.astro';
import FAQ from '../components/FAQ.astro';
import heroVideoSrc from '../assets/videos/scene-exported.mp4';
import { getCollection } from 'astro:content';

// Get portfolio projects
const allProjects = await getCollection('portfolio');
const featuredProjects = allProjects
  .filter(project => project.data.featured)
  .sort((a, b) => a.data.order - b.data.order)
  .slice(0, 4);

const services = [
  {
    title: "Brand Sprint",
    tagline: "Your complete brand identity in 2 weeks",
    duration: "2 WEEKS",
    features: [
      "2 distinct brand directions to choose from",
      "Logo system (primary, secondary, icon marks)",
      "Typography and color palette",
      "Brand guidelines document",
      "Homepage design concept",
      "5 brand application mockups"
    ]
  },
  {
    title: "Website Sprint",
    tagline: "AI-optimized websites that work everywhere",
    duration: "2 WEEKS",
    features: [
      "2 distinct design directions to choose from",
      "5-7 page responsive website (Astro framework)",
      "AI optimization (Schema.org, semantic markup)",
      "Optimized for Google, ChatGPT, and Perplexity",
      "Fast loading and mobile responsive",
      "1-hour handover training session"
    ]
  }
];

const faqItems = [
  {
    number: "01",
    question: "What makes Lumina7 different from other design studios?",
    answer: "We combine innovation and speed through AI-augmented workflows. This enables more exploration, breakthrough solutions, and rapid execution—without compromising thoughtful execution or quality. Like our name suggests (Lumina = light), we deliver at the speed of light while maintaining the highest standards."
  },
  {
    number: "02",
    question: "How do AI-augmented workflows benefit my project?", 
    answer: "AI-augmented design processes enable more creative exploration, faster iteration, and better solutions. We use cutting-edge tools to enhance our capabilities, allowing us to deliver innovative outcomes in shorter timeframes while maintaining focused execution and quality."
  },
  {
    number: "03",
    question: "Do you work with clients in different industries?",
    answer: "Yes, we work across various industries including technology, fintech, healthcare, e-commerce, and professional services. Our diverse experience allows us to bring fresh perspectives and proven approaches to each project."
  },
  {
    number: "04",
    question: "What is your approach to branding and design?",
    answer: "We focus on business outcomes first. Every decision drives tangible results—attracting customers and fueling growth. We combine expert thinking with innovative workflows to create brand experiences that work for your business goals."
  },
  {
    number: "05",
    question: "Do you work with startups and established businesses?",
    answer: "Absolutely. We partner with ambitious businesses at all stages, from early-stage startups to established enterprises. Our rapid, innovation-powered approach is especially valuable for businesses that need to compete and grow quickly."
  },
  {
    number: "06",
    question: "How do you ensure quality with rapid delivery?",
    answer: "Speed doesn't mean rushed work. We move fast through AI-augmented innovation and efficient processes, but every project receives focused attention and expert refinement. Our approach enables rapid iteration while maintaining professional quality throughout."
  }
];
---

<Layout 
  title="Lumina7 | Innovation-Powered Design at the Speed of Light"
  description="AI-augmented design studio delivering breakthrough brand experiences faster. We combine strategic thinking with innovative workflows to help ambitious businesses compete and grow."
>
  <Header />
  
  <!-- Hero Section -->
  <section class="pt-24 pb-20 px-4 sm:px-6 lg:px-8 bg-primary">
    <div class="max-w-7xl mx-auto">
      <div class="max-w-4xl">
        <h1 
          class="text-[2.75rem] sm:text-[3.3rem] md:text-[4.95rem] font-medium text-gray-900 dark:text-gray-100 mb-8 leading-[0.95] mt-8 tracking-tight transition-colors duration-300"
        >
          <span class="block">We design brands and websites, <span class="italic">fast.</span></span>
        </h1>
        
        <p class="text-body-lg text-primary max-w-3xl">
          Premium Brand and Website Sprints delivered in 2 weeks. Optimized for humans and AI agents. South African studio serving ambitious businesses.
        </p>
        <div class="mt-8 text-caption text-tertiary">
          [ Scroll down ]
        </div>
      </div>
    </div>
  </section>

  <!-- Hero Image Section -->
  <section class="px-6 lg:px-8 bg-primary">
    <div class="max-w-7xl mx-auto pb-20">
      <div class="relative w-full h-[440px] lg:h-[580px] bg-tertiary overflow-hidden rounded group">
        <video
          id="hero-video"
          class="w-full h-full object-cover rounded"
          autoplay
          muted
          loop
          playsinline
          preload="auto"
          aria-label="Lumina7 brand design and web development work for South African businesses"
        >
          <source src={heroVideoSrc} type="video/mp4" />
        </video>
        
        <button 
          id="video-control-btn"
          class="absolute top-6 left-6 z-20 p-2.5 rounded-[4px] bg-black/30 hover:bg-black/50 text-white backdrop-blur-[2px] transition-all duration-300 opacity-0 group-hover:opacity-100 focus:opacity-100"
          aria-label="Pause video"
        >
          <svg id="pause-icon" class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 9v6m4-6v6" />
          </svg>
          <svg id="play-icon" class="w-5 h-5 hidden" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M14.752 11.168l-3.197-2.132A1 1 0 0010 9.87v4.263a1 1 0 001.555.832l3.197-2.132a1 1 0 000-1.664z" />
          </svg>
        </button>
      </div>
    </div>
  </section>

  <!-- Services Section (2 Columns / 4 Quadrants) -->
  <section class="py-20 px-6 lg:px-8 bg-black dark:bg-black text-white relative overflow-hidden transition-colors duration-300">
    <!-- Background pattern -->
    <div class="absolute inset-0 opacity-5">
      <div class="absolute inset-0" style="background-image: radial-gradient(circle at 1px 1px, white 1px, transparent 0); background-size: 20px 20px;"></div>
    </div>
    
    <div class="max-w-7xl mx-auto relative z-10">
      <div class="grid md:grid-cols-2 border border-neutral-800 dark:border-gray-800">
        
        <!-- Service 1: Brand Sprint (Content Left) -->
        <div class="p-8 md:p-12 group hover:bg-neutral-900/50 dark:hover:bg-gray-900/50 transition-colors duration-300 border-b border-neutral-800 dark:border-gray-800 md:border-r">
          
          <h3 class="text-2xl md:text-3xl font-bold text-white mb-2 leading-tight transition-colors duration-300">
            {services[0].title}
          </h3>
          
          <p class="text-neutral-400 text-lg mb-10 leading-relaxed">
            {services[0].tagline}
          </p>

          <div class="mb-10">
            <h4 class="text-xs font-bold text-neutral-500 uppercase tracking-wider mb-6">WHAT'S INCLUDED</h4>
            <ul class="space-y-3">
              {services[0].features.map(feature => (
                <li class="flex items-start text-sm text-neutral-300">
                  <svg class="w-5 h-5 text-neutral-500 mr-3 flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
                  </svg>
                  <span>{feature}</span>
                </li>
              ))}
            </ul>
          </div>

          <a href="/services" class="inline-block px-6 py-3 bg-white text-black font-medium text-sm rounded-[4px] hover:bg-neutral-200 transition-colors duration-300">
            Learn more
          </a>
        </div>

        <!-- Service 1 Image (Right) -->
        <div class="relative min-h-[400px] border-b border-neutral-800 dark:border-gray-800 overflow-hidden group">
           <img 
            src="/assets/work/lumina7-arabica-1.jpg" 
            alt="Brand Sprint" 
            class="absolute inset-0 w-full h-full object-cover transition-transform duration-700 group-hover:scale-105 opacity-80 group-hover:opacity-100"
          />
        </div>

        <!-- Service 2 Image (Left) -->
        <div class="relative min-h-[400px] border-b md:border-b-0 border-neutral-800 dark:border-gray-800 md:border-r overflow-hidden group">
          <img 
            src="/assets/images/work/nexevo-website.jpeg" 
            alt="Website Sprint" 
            class="absolute inset-0 w-full h-full object-cover transition-transform duration-700 group-hover:scale-105 opacity-80 group-hover:opacity-100"
          />
        </div>

        <!-- Service 2: Website Sprint (Content Right) -->
        <div class="p-8 md:p-12 group hover:bg-neutral-900/50 dark:hover:bg-gray-900/50 transition-colors duration-300">
          
          <h3 class="text-2xl md:text-3xl font-bold text-white mb-2 leading-tight transition-colors duration-300">
            {services[1].title}
          </h3>
          
          <p class="text-neutral-400 text-lg mb-10 leading-relaxed">
            {services[1].tagline}
          </p>

          <div class="mb-10">
            <h4 class="text-xs font-bold text-neutral-500 uppercase tracking-wider mb-6">WHAT'S INCLUDED</h4>
            <ul class="space-y-3">
              {services[1].features.map(feature => (
                <li class="flex items-start text-sm text-neutral-300">
                  <svg class="w-5 h-5 text-neutral-500 mr-3 flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
                  </svg>
                  <span>{feature}</span>
                </li>
              ))}
            </ul>
          </div>

          <a href="/services" class="inline-block px-6 py-3 bg-white text-black font-medium text-sm rounded-[4px] hover:bg-neutral-200 transition-colors duration-300">
            Learn more
          </a>
        </div>

      </div>
    </div>
  </section>
  
  <script>
    // Video Play/Pause Toggle
    const video = document.getElementById('hero-video') as HTMLVideoElement | null;
    const toggleBtn = document.getElementById('video-control-btn');
    const playIcon = document.getElementById('play-icon');
    const pauseIcon = document.getElementById('pause-icon');

    if (video && toggleBtn && playIcon && pauseIcon) {
      toggleBtn.addEventListener('click', () => {
        if (video.paused) {
          video.play();
          playIcon.classList.add('hidden');
          pauseIcon.classList.remove('hidden');
          toggleBtn.setAttribute('aria-label', 'Pause video');
        } else {
          video.pause();
          pauseIcon.classList.add('hidden');
          playIcon.classList.remove('hidden');
          toggleBtn.setAttribute('aria-label', 'Play video');
        }
      });
    }
  </script>

  <!-- Recent Work Section -->
  <section class="py-20 bg-white dark:bg-black transition-colors duration-300 overflow-hidden">
    <div class="max-w-7xl mx-auto px-6 lg:px-8">
      <div class="mb-12 flex items-center justify-between">
        <h2 class="text-3xl md:text-4xl lg:text-5xl font-semibold text-neutral-900 dark:text-gray-100 transition-colors duration-300">
          Recent Work
        </h2>
        <div class="flex gap-4">
          <button id="scroll-left" class="p-2 rounded-full border border-neutral-200 dark:border-neutral-800 hover:bg-neutral-100 dark:hover:bg-neutral-900 transition-colors group" aria-label="Scroll left">
            <svg class="w-6 h-6 text-neutral-900 dark:text-white group-hover:-translate-x-0.5 transition-transform" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7" />
            </svg>
          </button>
          <button id="scroll-right" class="p-2 rounded-full border border-neutral-200 dark:border-neutral-800 hover:bg-neutral-100 dark:hover:bg-neutral-900 transition-colors group" aria-label="Scroll right">
            <svg class="w-6 h-6 text-neutral-900 dark:text-white group-hover:translate-x-0.5 transition-transform" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" />
            </svg>
          </button>
        </div>
      </div>
    </div>

    <!-- Scrollable Gallery -->
    <div class="max-w-7xl mx-auto">
      <div id="projects-gallery" class="flex overflow-x-auto gap-6 px-6 lg:px-8 pb-8 snap-x snap-mandatory scrollbar-hide">
        {featuredProjects.map((project) => (
          <div class="flex-none w-[85vw] sm:w-[400px] snap-center group rounded-[4px] overflow-hidden bg-white dark:bg-black shadow-lg border border-neutral-200 dark:border-neutral-800">
            <!-- Image -->
            <div class="relative aspect-[4/3] overflow-hidden">
              <img 
                src={project.data.heroImage} 
                alt={project.data.title}
                class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-700"
              />
            </div>

            <!-- Text Content -->
            <div class="p-6">
              <h3 class="text-xl font-semibold text-neutral-900 dark:text-white mb-1">
                {project.data.title}
              </h3>
              <p class="text-sm text-neutral-500 dark:text-neutral-400">
                {project.data.services[0]}
              </p>
            </div>
          </div>
        ))}
      </div>
    </div>
      
  </section>

  <script>
    const scrollContainer = document.getElementById('projects-gallery');
    const scrollLeftBtn = document.getElementById('scroll-left');
    const scrollRightBtn = document.getElementById('scroll-right');

    if (scrollContainer && scrollLeftBtn && scrollRightBtn) {
      scrollLeftBtn.addEventListener('click', () => {
        scrollContainer.scrollBy({ left: -420, behavior: 'smooth' });
      });

      scrollRightBtn.addEventListener('click', () => {
        scrollContainer.scrollBy({ left: 420, behavior: 'smooth' });
      });
    }
  </script>

  <FAQ faqItems={faqItems} />

  <CTA />

  <Footer />
</Layout>
