---
import Layout from '../layouts/Layout.astro';
import Footer from '../components/Footer.astro';
import WhatsAppButton from '../components/WhatsAppButton.astro';
---

<Layout
  title="Contact Us | Lumina7 Cape Town"
  description="Get in touch with Lumina7 about brand identity, website, print, or signage work. Send a message or WhatsApp us — we usually reply within a few hours."
>
  <section class="pt-24 pb-8 px-4 sm:px-6 lg:px-8">
    <div class="max-w-4xl mx-auto">
      <h1 class="text-heading-1 text-primary mb-4 mt-8">Get in touch</h1>
      <p class="text-body-lg text-secondary max-w-2xl">
        Tell us about your project and we'll come back to you within a few hours. Prefer WhatsApp? That works too.
      </p>
    </div>
  </section>

  <section class="py-12 px-4 sm:px-6 lg:px-8 bg-white dark:bg-[#0a0a0a] transition-colors duration-300">
    <div class="max-w-4xl mx-auto grid lg:grid-cols-[1.1fr_0.9fr] gap-12 lg:gap-16">
      <div>
        <form
          name="contact"
          method="POST"
          action="/success"
          data-netlify="true"
          netlify-honeypot="bot-field"
          class="space-y-6"
        >
          <input type="hidden" name="form-name" value="contact" />
          <p class="hidden">
            <label>
              Don't fill this out if you're human: <input name="bot-field" />
            </label>
          </p>

          <div>
            <label for="name" class="block text-sm font-medium text-primary mb-2">
              Name <span aria-hidden="true" class="text-tertiary">*</span>
            </label>
            <input
              type="text"
              id="name"
              name="name"
              required
              autocomplete="name"
              class="w-full min-h-[44px] px-4 py-3 rounded-[4px] border border-primary bg-secondary text-primary placeholder:text-tertiary focus:outline-none focus-visible:ring-1 focus-visible:ring-primary/60 transition-colors duration-300"
              placeholder="Your name"
            />
          </div>

          <div>
            <label for="email" class="block text-sm font-medium text-primary mb-2">
              Email <span aria-hidden="true" class="text-tertiary">*</span>
            </label>
            <input
              type="email"
              id="email"
              name="email"
              required
              autocomplete="email"
              class="w-full min-h-[44px] px-4 py-3 rounded-[4px] border border-primary bg-secondary text-primary placeholder:text-tertiary focus:outline-none focus-visible:ring-1 focus-visible:ring-primary/60 transition-colors duration-300"
              placeholder="you@company.co.za"
            />
          </div>

          <div>
            <label for="company" class="block text-sm font-medium text-primary mb-2">
              Company <span class="text-tertiary font-normal">(optional)</span>
            </label>
            <input
              type="text"
              id="company"
              name="company"
              autocomplete="organization"
              class="w-full min-h-[44px] px-4 py-3 rounded-[4px] border border-primary bg-secondary text-primary placeholder:text-tertiary focus:outline-none focus-visible:ring-1 focus-visible:ring-primary/60 transition-colors duration-300"
              placeholder="Your business name"
            />
          </div>

          <div>
            <label for="message" class="block text-sm font-medium text-primary mb-2">
              What do you need? <span aria-hidden="true" class="text-tertiary">*</span>
            </label>
            <textarea
              id="message"
              name="message"
              required
              rows="5"
              class="w-full px-4 py-3 rounded-[4px] border border-primary bg-secondary text-primary placeholder:text-tertiary focus:outline-none focus-visible:ring-1 focus-visible:ring-primary/60 transition-colors duration-300"
              placeholder="A quick summary of the project, timeline, and budget if you have one."
            ></textarea>
          </div>

          <button
            type="submit"
            class="inline-flex items-center gap-2 px-6 py-3 text-sm font-medium text-white bg-gray-900 dark:bg-white dark:text-gray-900 rounded-full hover:bg-gray-800 dark:hover:bg-gray-100 transition-colors duration-300 min-h-[44px] focus-visible:outline-none focus-visible:ring-1 focus-visible:ring-primary/60 focus-visible:ring-offset-2"
            data-event="contact_form_submit"
          >
            Send message
          </button>
        </form>
      </div>

      <aside class="border-t lg:border-t-0 lg:border-l border-primary pt-10 lg:pt-0 lg:pl-10 space-y-8">
        <div>
          <h2 class="text-xs font-medium uppercase tracking-wider text-tertiary mb-3">Prefer WhatsApp?</h2>
          <p class="text-sm text-secondary mb-4 leading-relaxed">
            No long forms, no commitment. Message us directly and we'll usually reply within a few hours.
          </p>
          <WhatsAppButton label="WhatsApp Us" size="md" eventSource="contact_page" />
        </div>
        <div>
          <h2 class="text-xs font-medium uppercase tracking-wider text-tertiary mb-3">Or email us</h2>
          <a href="mailto:hello@lumina7.co.za" class="text-sm text-secondary hover:text-primary transition-colors duration-300">hello@lumina7.co.za</a>
        </div>
        <div>
          <h2 class="text-xs font-medium uppercase tracking-wider text-tertiary mb-3">Credentials</h2>
          <p class="text-sm text-secondary leading-relaxed">
            B-BBEE Level 1 Contributor<br />
            Nexevo Studios (Pty) Ltd t/a Lumina7 Studio<br />
            Reg: 2025/019491/07
          </p>
        </div>
      </aside>
    </div>
  </section>

  <Footer />
</Layout>
