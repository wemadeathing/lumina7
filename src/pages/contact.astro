---
import Layout from '../layouts/Layout.astro';
import Footer from '../components/Footer.astro';
import FAQ from '../components/FAQ.astro';
import WhatsAppButton from '../components/WhatsAppButton.astro';

const faqItems = [
  { number: "01", question: "How quickly will you respond to my inquiry?", answer: "We typically respond within 24 hours to emails and 2 hours to WhatsApp messages during business hours." },
  { number: "02", question: "Do I need to have a detailed project plan?", answer: "No. Just tell us what you're thinking about. We'll ask questions and help refine the concept during our discovery conversation." },
  { number: "03", question: "What if I don't know what service I need?", answer: "That's exactly what the discovery call is for. We'll ask about your goals and recommend the right solution." },
  { number: "04", question: "Can you work with my budget?", answer: "We work with a range of budgets. If you share what you're working with, we can tell you what's possible at that investment level." }
];
---

<Layout 
  title="Contact | Lumina7 - Get in Touch"
  description="The fastest way to reach us is WhatsApp. Send us a message and we'll usually respond within a few hours. Mon-Fri 9am-5pm SAST."
>
  <script type="application/ld+json" slot="head">
    {JSON.stringify({
      "@context": "https://schema.org",
      "@type": "ProfessionalService",
      "name": "Lumina7",
      "image": "https://lumina7.co.za/assets/logos/L7-logo-blk.png",
      "url": "https://lumina7.co.za",
      "telephone": "+27814623628",
      "email": "hello@lumina7.co.za",
      "address": { "@type": "PostalAddress", "addressLocality": "Cape Town", "addressRegion": "Western Cape", "addressCountry": "ZA" },
      "geo": { "@type": "GeoCoordinates", "latitude": -33.9249, "longitude": 18.4241 },
      "openingHoursSpecification": { "@type": "OpeningHoursSpecification", "dayOfWeek": ["Monday", "Tuesday", "Wednesday", "Thursday", "Friday"], "opens": "09:00", "closes": "17:00" },
      "priceRange": "$$",
      "areaServed": { "@type": "Country", "name": "South Africa" },
      "serviceType": ["Brand Design", "Visual Identity", "Web Development", "Graphic Design", "Print", "Signage"]
    })}
  </script>
  
  <!-- Hero Section with Image -->
  <section class="pt-24 pb-20 px-4 sm:px-6 lg:px-8 bg-primary">
    <div class="max-w-7xl mx-auto">
      <div class="grid lg:grid-cols-2 gap-16 items-start">
        
        <!-- Left side - Hero Content and Contact Options -->
        <div class="space-y-16">
          <div>
            <h2 class="text-heading-1 text-primary mb-8 mt-8">
              Let's talk
            </h2>
            <p class="text-lg text-gray-600 dark:text-neutral-400 leading-relaxed mb-12 transition-colors">
              The fastest way to reach us is WhatsApp. Send us a message and we'll usually respond within a few hours.
            </p>
          </div>

          <!-- Primary CTA: WhatsApp -->
          <div class="space-y-4">
            <h2 class="text-lg text-gray-500 dark:text-neutral-500 font-medium">Chat via WhatsApp</h2>
            <p class="text-sm text-gray-600 dark:text-neutral-400 leading-relaxed">
              For quick questions or to get started immediately. We typically respond within 2 hours during business hours.
            </p>
            <WhatsAppButton label="WhatsApp: +27 81 462 3628" size="lg" />
          </div>

          <!-- Contact Form -->
          <div class="space-y-4">
            <h2 class="text-lg text-gray-500 dark:text-neutral-500 font-medium">Or send us a message</h2>
            <form action="https://formsubmit.co/hello@lumina7.co.za" method="POST" class="space-y-4">
              <input type="hidden" name="_next" value="https://lumina7.co.za/success" />
              <input type="hidden" name="_subject" value="New Contact Form Enquiry - Lumina7" />
              <input type="hidden" name="_captcha" value="false" />
              <input type="text" name="name" required placeholder="Name" class="w-full bg-white dark:bg-[#0a0a0a] border border-gray-300 dark:border-gray-700 rounded px-4 py-3 text-gray-900 dark:text-white placeholder-gray-500 focus:outline-none focus:ring-2 focus:ring-gray-400 dark:focus:ring-gray-600 transition-colors" />
              <input type="email" name="email" required placeholder="Email" class="w-full bg-white dark:bg-[#0a0a0a] border border-gray-300 dark:border-gray-700 rounded px-4 py-3 text-gray-900 dark:text-white placeholder-gray-500 focus:outline-none focus:ring-2 focus:ring-gray-400 dark:focus:ring-gray-600 transition-colors" />
              <textarea name="message" required rows={4} placeholder="Tell us about your project" class="w-full bg-white dark:bg-[#0a0a0a] border border-gray-300 dark:border-gray-700 rounded px-4 py-3 text-gray-900 dark:text-white placeholder-gray-500 focus:outline-none focus:ring-2 focus:ring-gray-400 dark:focus:ring-gray-600 transition-colors resize-none"></textarea>
              <button type="submit" class="px-6 py-3 text-sm font-medium text-white bg-gray-900 dark:bg-white dark:text-gray-900 rounded-full hover:bg-gray-800 dark:hover:bg-gray-100 transition-colors">
                Send message
              </button>
            </form>
          </div>

          <!-- Email -->
          <div class="space-y-4">
            <h2 class="text-lg text-gray-500 dark:text-neutral-500 font-medium">Send us an email</h2>
            <a href="mailto:hello@lumina7.co.za" class="block text-xl text-gray-900 dark:text-white hover:text-gray-600 dark:hover:text-neutral-300 transition-colors font-medium underline">
              hello@lumina7.co.za
            </a>
          </div>
        </div>

        <!-- Right side - Office Image -->
        <div class="aspect-square bg-gray-100 dark:bg-neutral-900 overflow-hidden rounded-2xl">
          <img 
            src="https://images.unsplash.com/photo-1497366216548-37526070297c?w=800&h=800&fit=crop&auto=format" 
            alt="Modern design studio office workspace in Cape Town, South Africa"
            class="w-full h-full object-cover"
          />
        </div>

      </div>
    </div>
  </section>

  <!-- Business Hours & Location Section -->
  <section class="py-20 px-6 lg:px-8 bg-white dark:bg-[#0a0a0a] transition-colors duration-300 ">
    <div class="max-w-7xl mx-auto">
      <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-12">
        <div class="space-y-4">
          <h3 class="text-xl font-medium text-gray-900 dark:text-white transition-colors">Our Hours</h3>
          <div class="text-gray-600 dark:text-neutral-400 space-y-2 transition-colors">
            <p>Monday - Friday</p>
            <p class="font-medium">9:00 AM - 5:00 PM SAST</p>
            <p class="text-sm">Saturday - Sunday: Closed</p>
          </div>
        </div>
        <div class="space-y-4">
          <h3 class="text-xl font-medium text-gray-900 dark:text-white transition-colors">Response Times</h3>
          <div class="text-gray-600 dark:text-neutral-400 space-y-2 transition-colors">
            <p>WhatsApp: 2 hours</p>
            <p>Email: 24 hours</p>
            <p class="text-sm text-gray-500 dark:text-neutral-500">(during business hours)</p>
          </div>
        </div>
        <div class="space-y-4">
          <h3 class="text-xl font-medium text-gray-900 dark:text-white transition-colors">Where we are</h3>
          <div class="text-gray-600 dark:text-neutral-400 space-y-2 transition-colors">
            <p>Cape Town, South Africa</p>
            <p class="text-sm text-gray-500 dark:text-neutral-500">We serve South African businesses and work with international clients</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <FAQ faqItems={faqItems} />

  <!-- Privacy Note -->
  <section class="py-12 px-6 lg:px-8 bg-white dark:bg-[#0a0a0a]  transition-colors duration-300">
    <div class="max-w-7xl mx-auto">
      <p class="text-sm text-gray-500 dark:text-neutral-500 text-center max-w-3xl mx-auto">
        We respect your privacy. Your information will only be used to contact you about your potential project. We comply with POPIA (Protection of Personal Information Act).
      </p>
    </div>
  </section>

  <Footer />
</Layout>
