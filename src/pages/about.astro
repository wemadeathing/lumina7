---
import Layout from '../layouts/Layout.astro';
import Footer from '../components/Footer.astro';
import CTA from '../components/CTA.astro';
import WhatsAppButton from '../components/WhatsAppButton.astro';

const whyLumina7 = [
  {
    number: "01",
    title: "Full-service studio",
    description: "We handle brand identity, websites, print, signage, and installations. Our clients are owner-run businesses, growing SMEs, and ambitious founders who want professional results without agency timelines or agency pricing."
  },
  {
    number: "02",
    title: "Lean and focused",
    description: "Faster turnarounds, direct communication, and real accountability — you'll always know who's working on your project and when to expect results."
  },
  {
    number: "03",
    title: "Led by experience",
    description: "Nasif Salaam, a designer and strategist with 20 years of experience building brands and digital products for businesses across South Africa and internationally."
  }
];

const capabilities = [
  { category: "Brand Identity", services: ["Logo Design", "Visual Systems", "Brand Guidelines", "Colour & Typography"] },
  { category: "Websites", services: ["Custom Design", "Mobile-first", "SEO Setup", "Contact & WhatsApp"] },
  { category: "Print & Signage", services: ["Business Cards", "Flyers & Brochures", "Menus", "Shopfront Signage", "Vehicle Branding"] }
];
---

<Layout 
  title="About Lumina7 | Cape Town Design Studio"
  description="Lumina7 is a Cape Town-based design studio helping South African businesses look their best. Brand identity, websites, print, signage, and installations."
>
  <!-- Hero Section -->
  <section class="pt-24 pb-20 px-4 sm:px-6 lg:px-8 bg-primary">
    <div class="max-w-7xl mx-auto">
      <div class="max-w-4xl">
        <h2 class="text-heading-1 text-primary mb-8 mt-8">
          About Lumina7
        </h2>
      </div>
    </div>
  </section>

  <!-- Team Image Section -->
  <section class="px-6 lg:px-8 py-24 bg-white dark:bg-[#0a0a0a] transition-colors duration-300 ">
    <div class="max-w-7xl mx-auto">
      <div class="aspect-[21/9] bg-gray-100 dark:bg-neutral-900 overflow-hidden mb-16 rounded-2xl">
        <img 
          src="/assets/images/hero.png" 
          alt="Lumina7 design studio workspace in Cape Town, South Africa"
          class="w-full h-full object-cover"
        />
      </div>
      
      <!-- Stats and Description -->
      <div class="grid lg:grid-cols-2 gap-16 mb-20">
        <div class="space-y-8">
          <div>
            <div class="text-4xl font-bold text-gray-900 dark:text-white mb-2 transition-colors">Cape Town</div>
            <div class="text-lg text-gray-600 dark:text-neutral-400 transition-colors">Headquarters</div>
          </div>
        </div>
        
        <div class="space-y-6">
          <p class="text-lg text-gray-600 dark:text-neutral-400 leading-relaxed transition-colors">
            Lumina7 is a Cape Town-based design studio helping South African businesses look their best — online and in the real world.
          </p>
          <p class="text-lg text-gray-600 dark:text-neutral-400 leading-relaxed transition-colors">
            We handle brand identity, websites, print, signage, and installations. Our clients are owner-run businesses, growing SMEs, and ambitious founders who want professional results without agency timelines or agency pricing.
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- Why Lumina7 Section -->
  <section class="py-24 px-6 lg:px-8 bg-white dark:bg-[#0a0a0a] transition-colors duration-300 ">
    <div class="max-w-4xl mx-auto">
      <h2 class="text-2xl md:text-3xl font-medium text-gray-900 dark:text-white mb-16">Why Lumina7</h2>
      
      <div class="space-y-20">
        {whyLumina7.map((item) => (
          <div class="flex items-start gap-6">
            <span class="text-sm text-gray-500 dark:text-neutral-500 font-medium mt-1">{item.number}</span>
            <div>
              <h3 class="text-2xl font-medium text-gray-900 dark:text-white mb-4 transition-colors">{item.title}</h3>
              <p class="text-gray-600 dark:text-neutral-400 leading-relaxed transition-colors">{item.description}</p>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Credentials Block -->
  <section class="py-24 px-6 lg:px-8 bg-white dark:bg-[#0a0a0a] transition-colors duration-300 ">
    <div class="max-w-7xl mx-auto">
      <div class="grid lg:grid-cols-2 gap-16">
        <div>
          <h2 class="text-2xl md:text-3xl font-medium text-gray-900 dark:text-white mb-8">Credentials</h2>
          <p class="text-sm font-medium text-gray-900 dark:text-white mb-2">B-BBEE Level 1 Contributor</p>
          <p class="text-sm text-gray-600 dark:text-neutral-400">Registered: Nexevo Studios (Pty) Ltd t/a Lumina7 Studio</p>
          <p class="text-sm text-gray-600 dark:text-neutral-400">Reg: 2025/019491/07</p>
          <p class="text-sm text-gray-600 dark:text-neutral-400">Cape Town, South Africa</p>
        </div>
        <div>
          <h2 class="text-2xl md:text-3xl font-medium text-gray-900 dark:text-white mb-8">Capabilities</h2>
          <div class="grid md:grid-cols-2 gap-12">
            {capabilities.map(capability => (
              <div class="space-y-6">
                <h3 class="text-xl font-medium text-gray-900 dark:text-white transition-colors">{capability.category}</h3>
                <ul class="space-y-3">
                  {capability.services.map(service => (
                    <li class="text-gray-600 dark:text-neutral-400 leading-relaxed transition-colors">{service}</li>
                  ))}
                </ul>
              </div>
            ))}
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="py-24 px-6 lg:px-8 bg-white dark:bg-[#0a0a0a]  transition-colors duration-300">
    <div class="max-w-4xl mx-auto">
      <h2 class="text-2xl md:text-3xl font-medium text-gray-900 dark:text-white mb-6">Want to work together?</h2>
      <WhatsAppButton label="WhatsApp us" />
    </div>
  </section>

  <CTA />
  <Footer />
</Layout>
