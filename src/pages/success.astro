---
import Layout from '../layouts/Layout.astro';
import Footer from '../components/Footer.astro';

const title = "Submission Received | Lumina7";
const description = "Thank you for contacting us. We'll be in touch shortly.";
---

<Layout title={title} description={description}>
  <main class="bg-primary min-h-screen text-gray-900 dark:text-white pt-24 pb-20 md:pt-32 md:pb-28 px-6 lg:px-8 flex flex-col items-center justify-center">
    <div class="max-w-2xl mx-auto text-center">
      
      <div class="w-20 h-20 bg-green-100 dark:bg-green-900/30 rounded-full flex items-center justify-center mx-auto mb-8">
        <svg class="w-10 h-10 text-green-600 dark:text-green-400" fill="none" viewBox="0 0 24 24" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
        </svg>
      </div>

      <h1 class="text-3xl md:text-4xl lg:text-5xl font-medium text-gray-900 dark:text-white mb-6 leading-tight">
        Message Received!
      </h1>
      
      <p class="text-gray-600 dark:text-gray-400 text-lg md:text-xl font-normal leading-relaxed mb-10">
        Thanks for reaching out. We've received your inquiry and will get back to you within 24 hours to schedule your discovery call.
      </p>

      <a href="/" class="inline-block px-8 py-4 bg-black dark:bg-white text-white dark:text-black font-medium text-base rounded-[4px] hover:bg-gray-800 dark:hover:bg-gray-200 transition-colors duration-300">
        Back to Home
      </a>
      
    </div>
  </main>

  <Footer />
</Layout>

