---
import Layout from '../../layouts/Layout.astro';
import Footer from '../../components/Footer.astro';
import WhatsAppButton from '../../components/WhatsAppButton.astro';
import { getCollection } from 'astro:content';

const projects = (await getCollection('portfolio'))
  .filter(p => p.data.services.some(s => /signage|print|brand|design/i.test(s)))
  .sort((a, b) => a.data.order - b.data.order)
  .slice(0, 3);

const included = [
  'Shopfront and building signage',
  'Banners and pull-up displays',
  'Vehicle wraps and branding',
  'Large format printing',
  'Wayfinding and interior graphics',
  'Production and installation management'
];

const steps = [
  { title: 'Site & specs', body: "We assess your space or vehicle, take measurements, and define what you need. We'll recommend materials and formats that suit your location and budget." },
  { title: 'Design & approve', body: "We design the signage to match your brand. You review and approve. We prepare files for production." },
  { title: 'Produce & install', body: "We work with trusted SA suppliers to produce your signage. We can coordinate installation or deliver ready-to-install pieces." }
];

const faqs = [
  { q: "Do you handle installation?", a: "Yes. We can manage production and installation for shopfront signs, interior graphics, and other signage. We work with trusted suppliers across South Africa." },
  { q: "What about vehicle branding?", a: "We design vehicle wraps and vinyl graphics. We'll prepare print-ready files and can recommend production partners who specialise in vehicle applications." }
];
---

<Layout 
  title="Signage & Installations | Lumina7 Cape Town"
  description="Shopfront signage, banners, vehicle branding, and large format — designed and produced. From R1,500."
>
  <section class="pt-24 pb-20 px-4 sm:px-6 lg:px-8 bg-primary">
    <div class="max-w-4xl mx-auto">
      <h2 class="text-heading-1 text-primary mb-6">
        Signage & Installations
      </h2>
      <p class="text-lg text-gray-600 dark:text-neutral-400 mb-8">
        Shopfront signage, banners, vehicle branding, and large format — designed and produced.
      </p>
      <WhatsAppButton label="Get a quote" />
    </div>
  </section>

  <section class="py-24 px-6 lg:px-8 bg-white dark:bg-[#0a0a0a] transition-colors duration-300 ">
    <div class="max-w-4xl mx-auto">
      <h2 class="text-2xl md:text-3xl font-medium text-gray-900 dark:text-white mb-6">What's included</h2>
      <ul class="space-y-3">
        {included.map((item) => (
          <li class="flex items-start gap-3 text-gray-600 dark:text-neutral-400">
            <span class="w-1.5 h-1.5 rounded-full bg-gray-400 dark:bg-neutral-500 mt-2 flex-shrink-0"></span>
            {item}
          </li>
        ))}
      </ul>
    </div>
  </section>

  <section class="py-24 px-6 lg:px-8 bg-white dark:bg-[#0a0a0a] transition-colors duration-300 ">
    <div class="max-w-4xl mx-auto">
      <h2 class="text-2xl md:text-3xl font-medium text-gray-900 dark:text-white mb-8">How it works</h2>
      <div class="space-y-8">
        {steps.map((step, i) => (
          <div>
            <h3 class="text-lg font-medium text-gray-900 dark:text-white mb-2">Step {i + 1}: {step.title}</h3>
            <p class="text-gray-600 dark:text-neutral-400">{step.body}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  {projects.length > 0 && (
    <section class="py-24 px-6 lg:px-8 bg-white dark:bg-[#0a0a0a] transition-colors duration-300 ">
      <div class="max-w-7xl mx-auto">
        <h2 class="text-2xl font-medium text-gray-900 dark:text-white mb-8">Recent work</h2>
        <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-6">
          {projects.map((project) => (
            <a href={`/work/${project.slug}`} class="group block rounded-2xl overflow-hidden bg-white dark:bg-neutral-800">
              <div class="aspect-[4/3] overflow-hidden">
                <img src={project.data.heroImage} alt={project.data.title} class="w-full h-full object-cover group-hover:scale-[1.03] transition-transform duration-500" loading="lazy" />
              </div>
              <div class="p-4">
                <h3 class="font-medium text-gray-900 dark:text-white">{project.data.company}</h3>
                <p class="text-sm text-gray-600 dark:text-neutral-400">{project.data.description}</p>
              </div>
            </a>
          ))}
        </div>
      </div>
    </section>
  )}

  <section class="py-24 px-6 lg:px-8 bg-white dark:bg-[#0a0a0a]  transition-colors duration-300">
    <div class="max-w-4xl mx-auto">
      <p class="text-xl font-medium text-gray-900 dark:text-white mb-6">Starting from R1,500</p>
      <div class="space-y-6">
        {faqs.map((faq) => (
          <div>
            <h3 class="font-medium text-gray-900 dark:text-white mb-2">{faq.q}</h3>
            <p class="text-gray-600 dark:text-neutral-400">{faq.a}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <section class="py-24 px-6 lg:px-8 bg-white dark:bg-[#0a0a0a]  transition-colors duration-300">
    <div class="max-w-2xl mx-auto text-center">
      <h2 class="text-2xl font-medium text-gray-900 dark:text-white mb-4">Ready to get started?</h2>
      <WhatsAppButton label="Get a quote" />
    </div>
  </section>

  <Footer />
</Layout>
