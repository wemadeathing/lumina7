---
import Layout from '../../layouts/Layout.astro';
import Footer from '../../components/Footer.astro';
import WhatsAppButton from '../../components/WhatsAppButton.astro';
import { getCollection } from 'astro:content';

const projects = (await getCollection('portfolio'))
  .filter(p => p.data.services.some(s => /brand|identity|logo|visual/i.test(s)))
  .sort((a, b) => a.data.order - b.data.order)
  .slice(0, 3);

const included = [
  'Logo design (primary + variations)',
  'Colour palette with HEX, RGB, and CMYK values',
  'Typography selection',
  'Brand guidelines document',
  'All final files (AI, EPS, SVG, PNG, PDF)'
];

const steps = [
  { title: 'Brief & discovery', body: "We learn about your business, audience, and goals. You share what makes you different and what you want your brand to say." },
  { title: 'Concepts & refinement', body: "We present initial directions. You give feedback, we refine until the identity feels right." },
  { title: 'Final delivery', body: "You receive all logo files, colour specs, typography choices, and brand guidelines. Ready to use everywhere." }
];

const faqs = [
  { q: "How long does a brand identity project take?", a: "Most brand identity projects are completed within 2–3 weeks from brief to final delivery. Timeline depends on the scope and how quickly you can review and approve concepts." },
  { q: "What file formats do I receive?", a: "You receive logo files in AI, EPS, SVG, PNG, and PDF formats — suitable for print, web, and any future use. We also provide a brand guidelines document." }
];
---

<Layout 
  title="Brand Identity | Lumina7 Cape Town"
  description="Logo, colour, typography and brand guidelines that make your business instantly recognisable. From R5,000. Fixed quotes."
>
  <section class="pt-24 pb-20 px-4 sm:px-6 lg:px-8 bg-primary">
    <div class="max-w-4xl mx-auto">
      <h2 class="text-heading-1 text-primary mb-6">
        Brand Identity
      </h2>
      <p class="text-lg text-gray-600 dark:text-neutral-400 mb-8">
        Logo, colour, typography and brand guidelines that make your business instantly recognisable.
      </p>
      <WhatsAppButton label="Get a quote" />
    </div>
  </section>

  <section class="py-24 px-6 lg:px-8 bg-white dark:bg-black transition-colors duration-300 border-t border-gray-200 dark:border-neutral-900">
    <div class="max-w-4xl mx-auto">
      <h2 class="text-2xl md:text-3xl font-medium text-gray-900 dark:text-white mb-6">What's included</h2>
      <ul class="space-y-3">
        {included.map((item) => (
          <li class="flex items-start gap-3 text-gray-600 dark:text-neutral-400">
            <span class="w-1.5 h-1.5 rounded-full bg-gray-400 dark:bg-neutral-500 mt-2 flex-shrink-0"></span>
            {item}
          </li>
        ))}
      </ul>
    </div>
  </section>

  <section class="py-24 px-6 lg:px-8 bg-white dark:bg-black transition-colors duration-300 border-t border-gray-200 dark:border-neutral-900">
    <div class="max-w-4xl mx-auto">
      <h2 class="text-2xl md:text-3xl font-medium text-gray-900 dark:text-white mb-8">How it works</h2>
      <div class="space-y-8">
        {steps.map((step, i) => (
          <div>
            <h3 class="text-lg font-medium text-gray-900 dark:text-white mb-2">Step {i + 1}: {step.title}</h3>
            <p class="text-gray-600 dark:text-neutral-400">{step.body}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  {projects.length > 0 && (
    <section class="py-24 px-6 lg:px-8 bg-white dark:bg-black transition-colors duration-300 border-t border-gray-200 dark:border-neutral-900">
      <div class="max-w-7xl mx-auto">
        <h2 class="text-2xl font-medium text-gray-900 dark:text-white mb-8">Recent work</h2>
        <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-6">
          {projects.map((project) => (
            <a href={`/work/${project.slug}`} class="group block rounded-2xl overflow-hidden bg-white dark:bg-neutral-800">
              <div class="aspect-[4/3] overflow-hidden">
                <img src={project.data.heroImage} alt={project.data.title} class="w-full h-full object-cover group-hover:scale-[1.03] transition-transform duration-500" loading="lazy" />
              </div>
              <div class="p-4">
                <h3 class="font-medium text-gray-900 dark:text-white">{project.data.company}</h3>
                <p class="text-sm text-gray-600 dark:text-neutral-400">{project.data.description}</p>
              </div>
            </a>
          ))}
        </div>
      </div>
    </section>
  )}

  <section class="py-24 px-6 lg:px-8 bg-white dark:bg-black border-t border-gray-200 dark:border-neutral-900 transition-colors duration-300">
    <div class="max-w-4xl mx-auto">
      <p class="text-xl font-medium text-gray-900 dark:text-white mb-6">Starting from R5,000</p>
      <div class="space-y-6">
        {faqs.map((faq) => (
          <div>
            <h3 class="font-medium text-gray-900 dark:text-white mb-2">{faq.q}</h3>
            <p class="text-gray-600 dark:text-neutral-400">{faq.a}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <section class="py-20 px-6 lg:px-8 bg-gray-50 dark:bg-neutral-900 transition-colors duration-300">
    <div class="max-w-2xl mx-auto text-center">
      <h2 class="text-2xl font-medium text-gray-900 dark:text-white mb-4">Ready to get started?</h2>
      <WhatsAppButton label="Get a quote" />
    </div>
  </section>

  <Footer />
</Layout>
