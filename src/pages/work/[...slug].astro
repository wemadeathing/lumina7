---
import { type CollectionEntry, getCollection } from 'astro:content';
import Layout from '../../layouts/Layout.astro';
import Footer from '../../components/Footer.astro';
import CTA from '../../components/CTA.astro';

export async function getStaticPaths() {
  const projects = await getCollection('portfolio');
  return projects.map((project) => ({
    params: { slug: project.slug },
    props: project,
  }));
}

type Props = CollectionEntry<'portfolio'>;

const project = Astro.props;
const { Content } = await project.render();

// Get related projects (same category, excluding current)
const allProjects = await getCollection('portfolio');
const relatedProjects = allProjects
  .filter(p => p.slug !== project.slug && p.data.category === project.data.category)
  .slice(0, 3);

const isGalleryLayout = project.data.caseStudyLayout === 'gallery';
const galleryImages = project.data.images.length > 0 ? project.data.images : [project.data.heroImage];

function clientNameFromImagePath(path: string) {
  const filename = path.split('/').pop() ?? '';
  const base = filename.replace(/\.[^.]+$/, '').replace(/-logo$/i, '');
  return base
    .split(/[-_]/)
    .filter(Boolean)
    .map(word => word.charAt(0).toUpperCase() + word.slice(1))
    .join(' ');
}
---

<Layout title={`${project.data.title} | Lumina7`} description={project.data.description} image={project.data.heroImage}>
  <!-- BreadcrumbList Structured Data -->
  <script type="application/ld+json" slot="head">
    {JSON.stringify({
      "@context": "https://schema.org",
      "@type": "BreadcrumbList",
      "itemListElement": [
        {
          "@type": "ListItem",
          "position": 1,
          "name": "Home",
          "item": "https://lumina7.co.za"
        },
        {
          "@type": "ListItem",
          "position": 2,
          "name": "Work",
          "item": "https://lumina7.co.za/work"
        },
        {
          "@type": "ListItem",
          "position": 3,
          "name": project.data.company,
          "item": `https://lumina7.co.za/work/${project.slug}`
        }
      ]
    })}
  </script>
  
  <!-- CreativeWork Structured Data -->
  <script type="application/ld+json" slot="head">
    {JSON.stringify({
      "@context": "https://schema.org",
      "@type": "CreativeWork",
      "name": project.data.title,
      "description": project.data.description,
      "image": project.data.heroImage,
      "creator": {
        "@type": "Organization",
        "name": "Lumina7"
      },
      "datePublished": project.data.year,
      "keywords": project.data.services.join(", "),
      "genre": project.data.category,
      "url": `https://lumina7.co.za/work/${project.slug}`
    })}
  </script>
  
  {isGalleryLayout ? (
    <>
      <!-- Gallery Hero -->
      <section class="pt-16 pb-8 px-6 lg:px-8">
        <div class="max-w-7xl mx-auto">
          <nav class="mb-8">
            <div class="flex items-center space-x-2 text-sm text-gray-500 dark:text-gray-400 transition-colors duration-300">
              <a href="/" class="hover:text-gray-900 dark:hover:text-gray-100 transition-colors">Home</a>
              <span>/</span>
              <a href="/work" class="hover:text-gray-900 dark:hover:text-gray-100 transition-colors">Work</a>
              <span>/</span>
              <span class="text-gray-900 dark:text-gray-100">{project.data.company}</span>
            </div>
          </nav>

          <div class="max-w-5xl">
            <span class="text-xs uppercase tracking-[0.5em] text-gray-500 dark:text-gray-400 block mb-8 transition-colors duration-300">
              {project.data.category}
            </span>
            <h1 class="text-heading-1 text-primary mb-6">
              {project.data.company}
            </h1>
            <p class="text-2xl md:text-[2rem] text-gray-600 dark:text-gray-400 leading-tight max-w-3xl transition-colors duration-300">
              {project.data.description}
            </p>
          </div>
        </div>
      </section>

      <!-- Featured Image -->
      <section class="px-6 lg:px-8 py-0 bg-white dark:bg-[#0a0a0a] transition-colors duration-300">
        <div class="max-w-6xl mx-auto">
          <div class="relative overflow-hidden bg-gray-100 dark:bg-neutral-100 rounded-2xl transition-colors duration-300">
            <img
              src={project.data.heroImage}
              alt={project.data.title}
              class="w-full h-[240px] sm:h-[360px] md:h-[480px] lg:h-[560px] object-cover"
            />
          </div>
        </div>
      </section>

      <!-- Gallery Explainer -->
      <section class="py-16 px-6 lg:px-8 bg-white dark:bg-[#0a0a0a] transition-colors duration-300">
        <div class="max-w-7xl mx-auto grid lg:grid-cols-[minmax(260px,0.8fr)_minmax(0,1.2fr)] gap-12 lg:gap-20">
          <aside class="grid sm:grid-cols-2 lg:grid-cols-1 gap-6 self-start">
            <div class="border-t border-gray-200 dark:border-neutral-800 pt-5">
              <p class="text-xs font-semibold text-gray-500 dark:text-gray-400 uppercase tracking-wider mb-2 transition-colors duration-300">Marks</p>
              <p class="text-3xl font-medium text-gray-900 dark:text-gray-100 transition-colors duration-300">{galleryImages.length}+</p>
            </div>
            <div class="border-t border-gray-200 dark:border-neutral-800 pt-5">
              <p class="text-xs font-semibold text-gray-500 dark:text-gray-400 uppercase tracking-wider mb-2 transition-colors duration-300">Scope</p>
              <p class="text-gray-700 dark:text-gray-300 text-sm tracking-wide transition-colors duration-300">{project.data.services.join(', ')}</p>
            </div>
            <div class="border-t border-gray-200 dark:border-neutral-800 pt-5">
              <p class="text-xs font-semibold text-gray-500 dark:text-gray-400 uppercase tracking-wider mb-2 transition-colors duration-300">Clients</p>
              <p class="text-gray-700 dark:text-gray-300 text-sm tracking-wide transition-colors duration-300">{project.data.client}</p>
            </div>
          </aside>

          <div class="leading-relaxed text-lg text-gray-700 dark:text-gray-300 space-y-8 transition-colors duration-300">
            <Content />
          </div>
        </div>
      </section>

      <!-- Logo Gallery -->
      <section class="pb-20 px-6 lg:px-8 bg-white dark:bg-[#0a0a0a] transition-colors duration-300">
        <div class="max-w-7xl mx-auto">
          <div class="grid grid-cols-2 md:grid-cols-3 lg:grid-cols-4 gap-4 sm:gap-6">
            {galleryImages.map((image, index) => (
              <button type="button" class="bg-gray-50 dark:bg-neutral-100 p-3 sm:p-4 cursor-zoom-in group rounded transition-colors duration-300 focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-gray-900 dark:focus-visible:ring-white focus-visible:ring-offset-4 focus-visible:ring-offset-white dark:focus-visible:ring-offset-[#0a0a0a]" data-modal-image={image} aria-label={`View ${clientNameFromImagePath(image)} logo design`}>
                <img
                  src={image}
                  alt={`${clientNameFromImagePath(image)} logo design by Lumina7`}
                  class="w-full aspect-[4/3] object-contain group-hover:scale-[1.03] transition-transform duration-500"
                  loading="lazy"
                />
              </button>
            ))}
          </div>
        </div>
      </section>
    </>
  ) : (
    <>
      <!-- Hero Section -->
      <section class="pt-24 pb-0 px-6 lg:px-8">
        <div class="max-w-6xl mx-auto">
          <!-- Breadcrumb -->
          <nav class="mb-10">
            <div class="flex items-center space-x-2 text-sm text-gray-500 dark:text-gray-400 transition-colors duration-300">
              <a href="/" class="hover:text-gray-900 dark:hover:text-gray-100 transition-colors">Home</a>
              <span>/</span>
              <a href="/work" class="hover:text-gray-900 dark:hover:text-gray-100 transition-colors">Work</a>
              <span>/</span>
              <span class="text-gray-900 dark:text-gray-100">{project.data.company}</span>
            </div>
          </nav>

          <!-- Hero Content -->
          <div class="mb-12">
            <div class="max-w-5xl">
              <span class="text-xs uppercase tracking-[0.5em] text-gray-500 dark:text-gray-400 block mb-8 transition-colors duration-300">
                {project.data.category}
              </span>
              <h1 class="text-heading-1 text-primary mb-6">
                {project.data.company}
              </h1>
              <p class="text-2xl md:text-[2rem] text-gray-600 dark:text-gray-400 leading-tight max-w-3xl transition-colors duration-300">
                {project.data.title}
              </p>
            </div>
          </div>
        </div>
      </section>

      <!-- Hero Image -->
      <section class="px-6 lg:px-8 py-0 bg-white dark:bg-[#0a0a0a]  transition-colors duration-300">
        <div class="max-w-6xl mx-auto">
          <div class="relative overflow-hidden bg-gray-100 dark:bg-[#0a0a0a] rounded-2xl transition-colors duration-300">
            <img 
              src={project.data.heroImage} 
              alt={project.data.title}
              class="w-full h-[280px] sm:h-[400px] md:h-[500px] lg:h-[600px] object-cover"
            />
          </div>
        </div>
      </section>

      <!-- Project Overview -->
      <section class="py-20 px-6 lg:px-8 bg-white dark:bg-[#0a0a0a]  transition-colors duration-300">
        <div class="max-w-6xl mx-auto grid md:grid-cols-[minmax(0,1fr)_minmax(0,2fr)] gap-12">
          <aside class="space-y-8 md:sticky md:top-32 self-start">
            <div>
              <h3 class="text-xs font-semibold text-gray-500 dark:text-gray-400 uppercase tracking-wider mb-3 transition-colors duration-300">Year</h3>
              <p class="text-gray-900 dark:text-gray-100 text-sm transition-colors duration-300">{project.data.year}</p>
            </div>
            <div>
              <h3 class="text-xs font-semibold text-gray-500 dark:text-gray-400 uppercase tracking-wider mb-3 transition-colors duration-300">Scope</h3>
              <ul class="space-y-2">
                {project.data.services.map(service => (
                  <li class="text-gray-700 dark:text-gray-300 text-sm tracking-wide transition-colors duration-300">{service}</li>
                ))}
              </ul>
            </div>
            {project.data.client && (
              <div>
                <h4 class="text-xs font-semibold text-gray-500 dark:text-gray-400 uppercase tracking-wider mb-3 transition-colors duration-300">Client</h4>
                <p class="text-gray-700 dark:text-gray-300 text-sm tracking-wide transition-colors duration-300">{project.data.client}</p>
              </div>
            )}
          </aside>
          <div class="space-y-10">
            <div class="leading-relaxed text-lg text-gray-700 dark:text-gray-300 space-y-8 transition-colors duration-300">
              <Content />
            </div>
          </div>
        </div>
      </section>

      <!-- Project Content -->
      <section class="py-20 px-6 lg:px-8 bg-white dark:bg-[#0a0a0a]  transition-colors duration-300">
        <div class="max-w-6xl mx-auto">
          {project.data.images && project.data.images.length > 0 && (
            <div class="grid gap-10 md:grid-cols-2">
              {project.data.images.slice(0, 6).map((image, index) => (
                <button type="button" class="bg-gray-100 dark:bg-neutral-900 overflow-hidden group cursor-zoom-in rounded-2xl transition-colors duration-300 focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-gray-900 dark:focus-visible:ring-white focus-visible:ring-offset-4 focus-visible:ring-offset-white dark:focus-visible:ring-offset-[#0a0a0a]" data-modal-image={image} aria-label={`View ${project.data.company} ${project.data.category} project photo ${index + 1}`}>
                  <img
                    src={image}
                    alt={`${project.data.company} ${project.data.category} project photo ${index + 1}`}
                    class="w-full aspect-[4/3] object-cover group-hover:scale-[1.03] transition-transform duration-500"
                    loading="lazy"
                  />
                </button>
              ))}
            </div>
          )}
        </div>
      </section>
    </>
  )}

  <!-- Image Modal -->
  <div id="imageModal" class="fixed inset-0 bg-black dark:bg-[#0a0a0a] bg-opacity-90 z-[10000] hidden items-center justify-center p-4" role="dialog" aria-modal="true" aria-hidden="true" aria-label="Project image preview">
    <button 
      id="closeModal" 
      class="absolute top-6 right-6 text-white hover:text-gray-300 dark:hover:text-gray-200 transition-colors z-[10020]"
      type="button"
      aria-label="Close modal"
    >
      <svg class="w-8 h-8 pointer-events-none" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"></path>
      </svg>
    </button>
    <div class="max-w-7xl max-h-[90vh] w-full h-full flex items-center justify-center">
      <img 
        id="modalImage" 
        src="" 
        alt="Full size image"
        class="max-w-full max-h-full object-contain bg-white/95 rounded-2xl p-4 sm:p-6"
      />
    </div>
  </div>

  <!-- Related Projects -->
  {relatedProjects.length > 0 && (
    <section class="py-20 px-6 lg:px-8 bg-white dark:bg-[#0a0a0a]  transition-colors duration-300">
      <div class="max-w-6xl mx-auto">
        <div class="text-center mb-16">
          <h2 class="text-heading-2 text-primary mb-4">More {project.data.category} Work</h2>
          <p class="text-lg text-gray-600 dark:text-gray-400 max-w-2xl mx-auto transition-colors duration-300">Explore other projects in this category</p>
        </div>
        <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-8 lg:gap-12">
          {relatedProjects.map(relatedProject => (
            <article class="group cursor-pointer">
              <a href={`/work/${relatedProject.slug}`} class="block">
                <div class="relative overflow-hidden bg-gray-100 dark:bg-neutral-900 mb-6 rounded-2xl transition-colors duration-300">
                  <img
                    src={relatedProject.data.heroImage}
                    alt={relatedProject.data.title}
                    class="w-full h-64 object-cover"
                    loading="lazy"
                  />
                </div>
                <div>
                  <span class="text-xs uppercase tracking-[0.3em] text-gray-500 dark:text-gray-400 mb-2 block transition-colors duration-300">
                    {relatedProject.data.category}
                  </span>
                  <h3 class="text-xl font-medium text-gray-900 dark:text-gray-100 mb-3 group-hover:text-gray-600 dark:group-hover:text-gray-400 transition-colors">
                    {relatedProject.data.company}
                  </h3>
                  <p class="text-gray-600 dark:text-gray-400 mb-4 leading-relaxed transition-colors duration-300">
                    {relatedProject.data.title}
                  </p>
                  <div class="flex flex-wrap gap-4">
                    {relatedProject.data.services.slice(0, 2).map(service => (
                      <span class="text-xs uppercase tracking-[0.2em] text-gray-500 dark:text-gray-400 transition-colors duration-300">
                        {service}
                      </span>
                    ))}
                  </div>
                </div>
              </a>
            </article>
          ))}
        </div>
      </div>
    </section>
  )}

  <CTA />

  <Footer />
</Layout>

<style>
  .prose {
    color: var(--text-secondary);
  }
  
  .prose h1, .prose h2, .prose h3, .prose h4, .prose h5, .prose h6 {
    color: var(--text-primary);
    font-weight: 600;
  }
  
  .prose h1 {
    font-size: 2.25rem;
    line-height: 2.5rem;
    margin-top: 2rem;
    margin-bottom: 1rem;
  }
  
  .prose h2 {
    font-size: 1.875rem;
    line-height: 2.25rem;
    margin-top: 2rem;
    margin-bottom: 1rem;
  }
  
  .prose h3 {
    font-size: 1.5rem;
    line-height: 2rem;
    margin-top: 1.5rem;
    margin-bottom: 0.75rem;
  }
  
  .prose p {
    margin-bottom: 1.25rem;
    line-height: 1.75;
  }
  
  .prose ul, .prose ol {
    margin-bottom: 1.25rem;
    padding-left: 1.5rem;
  }
  
  .prose li {
    margin-bottom: 0.5rem;
  }
  
  .prose a {
    color: var(--text-primary);
    text-decoration: underline;
  }
  
  .prose a:hover {
    color: var(--text-secondary);
  }
  
  .prose strong {
    font-weight: 600;
    color: var(--text-primary);
  }
  
  .prose blockquote {
    border-left: 4px solid var(--border-primary);
    padding-left: 1rem;
    margin: 1.5rem 0;
    font-style: italic;
    color: var(--text-tertiary);
  }
</style>
