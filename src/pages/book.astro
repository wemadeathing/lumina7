---
import Layout from '../layouts/Layout.astro';
import Footer from '../components/Footer.astro';

const title = "Book a Discovery Call | Lumina7";
const description = "Book your 30-minute discovery call. Let's talk about your project, timeline, and how we can help.";
---

<Layout title={title} description={description} useGlobalTopGradient={false}>
  <main class="bg-primary min-h-screen text-gray-900 dark:text-white pt-24 pb-20 md:pt-32 md:pb-28 px-6 lg:px-8 relative isolate">
    <!-- Top Glow Effect -->
    <div class="absolute -top-20 left-1/2 -translate-x-1/2 w-[120%] h-64 bg-gradient-to-r from-blue-600/60 via-purple-600/60 to-pink-600/60 blur-[100px] opacity-100 dark:opacity-80 -z-10 pointer-events-none"></div>
    <div class="max-w-3xl mx-auto">
      
      <!-- HEADER SECTION -->
      <div class="mb-12">
        <nav class="flex text-sm text-gray-500 dark:text-gray-400 mb-8" aria-label="Breadcrumb">
          <a href="/" class="hover:text-black dark:hover:text-white transition-colors">Home</a>
          <span class="mx-2">&gt;</span>
          <span class="text-gray-900 dark:text-white">Book Discovery Call</span>
        </nav>
        
        <h2 class="text-heading-1 text-primary mb-6">
          Book Your 30-Minute Discovery Call
        </h2>
        
        <p class="text-gray-600 dark:text-gray-400 text-lg md:text-xl font-normal max-w-2xl leading-relaxed">
          No pressure, no sales pitch. Just a conversation about your project, timeline, and how we can help.
        </p>
      </div>

      <!-- FORM SECTION -->
      <div class="mb-20">
        <div class="border border-gray-200 dark:border-gray-800 rounded-3xl p-10 bg-white/60 dark:bg-gray-900/30 backdrop-blur-md">
          <h2 class="text-2xl font-bold text-gray-900 dark:text-white mb-4">Request a discovery call</h2>
          <p class="text-gray-600 dark:text-gray-400 mb-8">
            Share your details and we'll get back within 24 hours to schedule your call.
          </p>
          
          <form 
            name="discovery-call" 
            method="POST" 
            action="https://formsubmit.co/hello@lumina7.co.za"
            data-netlify="true" 
            data-netlify-honeypot="bot-field"
            class="space-y-6"
            id="discovery-form"
            novalidate
          >
            <p class="hidden">
              <label>Don’t fill this out if you’re human: <input name="bot-field" /></label>
            </p>
            <input type="hidden" name="form-name" value="discovery-call" />
            <input type="hidden" name="_next" value="https://lumina7.co.za/success">
            <input type="hidden" name="_subject" value="New Discovery Call Request!">
            <input type="hidden" name="_captcha" value="false">

            <!-- Name & Email -->
            <div class="grid md:grid-cols-2 gap-6">
              <div>
                <label for="name" class="sr-only">Name</label>
                <input 
                  type="text" 
                  id="name" 
                  name="name" 
                  placeholder="Name *" 
                  required
                  class="w-full bg-white dark:bg-[#0a0a0a] border border-gray-300 dark:border-gray-800 rounded p-3 text-gray-900 dark:text-white placeholder-gray-500 focus:outline-none focus:border-gray-400 dark:focus:border-gray-600 transition-colors"
                />
                <p class="mt-1 text-sm text-red-500 hidden" id="name-error">Please enter your name</p>
              </div>
              
              <div>
                <label for="email" class="sr-only">Email</label>
                <input 
                  type="email" 
                  id="email" 
                  name="email" 
                  placeholder="Email *" 
                  required
                  class="w-full bg-white dark:bg-[#0a0a0a] border border-gray-300 dark:border-gray-800 rounded p-3 text-gray-900 dark:text-white placeholder-gray-500 focus:outline-none focus:border-gray-400 dark:focus:border-gray-600 transition-colors"
                />
                <p class="mt-1 text-sm text-red-500 hidden" id="email-error">Please enter a valid email address</p>
              </div>
            </div>

            <!-- Phone & Company -->
            <div class="grid md:grid-cols-2 gap-6">
              <div>
                <label for="phone" class="sr-only">Phone Number</label>
                <input 
                  type="tel" 
                  id="phone" 
                  name="phone" 
                  placeholder="Phone Number" 
                  class="w-full bg-white dark:bg-[#0a0a0a] border border-gray-300 dark:border-gray-800 rounded p-3 text-gray-900 dark:text-white placeholder-gray-500 focus:outline-none focus:border-gray-400 dark:focus:border-gray-600 transition-colors"
                />
              </div>

              <div>
                <label for="company" class="sr-only">Company/Project Name</label>
                <input 
                  type="text" 
                  id="company" 
                  name="company" 
                  placeholder="Company/Project Name" 
                  class="w-full bg-white dark:bg-[#0a0a0a] border border-gray-300 dark:border-gray-800 rounded p-3 text-gray-900 dark:text-white placeholder-gray-500 focus:outline-none focus:border-gray-400 dark:focus:border-gray-600 transition-colors"
                />
              </div>
            </div>

            <!-- Service Interest -->
            <div>
              <p class="text-sm text-gray-500 dark:text-gray-400 mb-3 font-medium">Service I'm interested in:</p>
              <div class="flex flex-wrap gap-4 sm:gap-6">
                <label class="flex items-center cursor-pointer group">
                  <input type="radio" name="interest" value="Brand Identity" class="sr-only peer" />
                  <div class="w-5 h-5 border border-gray-400 dark:border-gray-600 rounded-full mr-3 flex items-center justify-center peer-checked:border-black dark:peer-checked:border-white peer-checked:bg-black dark:peer-checked:bg-white transition-colors">
                    <div class="w-2.5 h-2.5 bg-white dark:bg-[#0a0a0a] rounded-full opacity-0 peer-checked:opacity-100"></div>
                  </div>
                  <span class="text-gray-600 dark:text-gray-300 group-hover:text-black dark:group-hover:text-white transition-colors">Brand Identity</span>
                </label>
                <label class="flex items-center cursor-pointer group">
                  <input type="radio" name="interest" value="Print & Marketing" class="sr-only peer" />
                  <div class="w-5 h-5 border border-gray-400 dark:border-gray-600 rounded-full mr-3 flex items-center justify-center peer-checked:border-black dark:peer-checked:border-white peer-checked:bg-black dark:peer-checked:bg-white transition-colors">
                    <div class="w-2.5 h-2.5 bg-white dark:bg-[#0a0a0a] rounded-full opacity-0 peer-checked:opacity-100"></div>
                  </div>
                  <span class="text-gray-600 dark:text-gray-300 group-hover:text-black dark:group-hover:text-white transition-colors">Print & Marketing</span>
                </label>
                <label class="flex items-center cursor-pointer group">
                  <input type="radio" name="interest" value="Signage & Installations" class="sr-only peer" />
                  <div class="w-5 h-5 border border-gray-400 dark:border-gray-600 rounded-full mr-3 flex items-center justify-center peer-checked:border-black dark:peer-checked:border-white peer-checked:bg-black dark:peer-checked:bg-white transition-colors">
                    <div class="w-2.5 h-2.5 bg-white dark:bg-[#0a0a0a] rounded-full opacity-0 peer-checked:opacity-100"></div>
                  </div>
                  <span class="text-gray-600 dark:text-gray-300 group-hover:text-black dark:group-hover:text-white transition-colors">Signage</span>
                </label>
                <label class="flex items-center cursor-pointer group">
                  <input type="radio" name="interest" value="Website Design" class="sr-only peer" />
                  <div class="w-5 h-5 border border-gray-400 dark:border-gray-600 rounded-full mr-3 flex items-center justify-center peer-checked:border-black dark:peer-checked:border-white peer-checked:bg-black dark:peer-checked:bg-white transition-colors">
                    <div class="w-2.5 h-2.5 bg-white dark:bg-[#0a0a0a] rounded-full opacity-0 peer-checked:opacity-100"></div>
                  </div>
                  <span class="text-gray-600 dark:text-gray-300 group-hover:text-black dark:group-hover:text-white transition-colors">Website</span>
                </label>
                <label class="flex items-center cursor-pointer group">
                  <input type="radio" name="interest" value="Social Media & Digital" class="sr-only peer" />
                  <div class="w-5 h-5 border border-gray-400 dark:border-gray-600 rounded-full mr-3 flex items-center justify-center peer-checked:border-black dark:peer-checked:border-white peer-checked:bg-black dark:peer-checked:bg-white transition-colors">
                    <div class="w-2.5 h-2.5 bg-white dark:bg-[#0a0a0a] rounded-full opacity-0 peer-checked:opacity-100"></div>
                  </div>
                  <span class="text-gray-600 dark:text-gray-300 group-hover:text-black dark:group-hover:text-white transition-colors">Social & Digital</span>
                </label>
                <label class="flex items-center cursor-pointer group">
                  <input type="radio" name="interest" value="Not sure yet" class="sr-only peer" />
                  <div class="w-5 h-5 border border-gray-400 dark:border-gray-600 rounded-full mr-3 flex items-center justify-center peer-checked:border-black dark:peer-checked:border-white peer-checked:bg-black dark:peer-checked:bg-white transition-colors">
                    <div class="w-2.5 h-2.5 bg-white dark:bg-[#0a0a0a] rounded-full opacity-0 peer-checked:opacity-100"></div>
                  </div>
                  <span class="text-gray-600 dark:text-gray-300 group-hover:text-black dark:group-hover:text-white transition-colors">Not sure yet</span>
                </label>
              </div>
            </div>

            <!-- Project Details -->
            <div>
              <label for="project-details" class="block text-sm text-gray-500 dark:text-gray-400 mb-2 font-medium">Project details</label>
              <textarea 
                id="project-details" 
                name="project-details" 
                rows="3" 
                maxlength="300"
                placeholder="Briefly describe your project, goals, or timeline. What do you need help with?"
                class="w-full bg-white dark:bg-[#0a0a0a] border border-gray-300 dark:border-gray-800 rounded p-3 text-gray-900 dark:text-white placeholder-gray-500 focus:outline-none focus:border-gray-400 dark:focus:border-gray-600 transition-colors resize-none"
              ></textarea>
            </div>

            <!-- Preferred Time (Custom Dropdown) -->
            <div>
              <label for="preferred-time-input" class="block text-sm text-gray-500 dark:text-gray-400 mb-2 font-medium">Preferred days/times for call</label>
              <input type="hidden" name="preferred-time" id="preferred-time-input" value="" />
              <div class="relative" id="preferred-time-dropdown">
                <button
                  type="button"
                  id="preferred-time-trigger"
                  aria-haspopup="listbox"
                  aria-expanded="false"
                  aria-labelledby="preferred-time-label"
                  class="w-full bg-white dark:bg-[#0a0a0a] border border-gray-300 dark:border-gray-800 rounded p-3 text-left text-gray-900 dark:text-white focus:outline-none focus:border-gray-400 dark:focus:border-gray-600 focus-visible:ring-1 focus-visible:ring-primary/60 transition-colors flex items-center justify-between"
                >
                  <span id="preferred-time-label" class="text-gray-500 dark:text-gray-400">Select preferred time</span>
                  <svg class="w-4 h-4 text-gray-500 dark:text-gray-400 shrink-0 ml-2 transition-transform duration-200" aria-hidden="true" viewBox="0 0 20 20" fill="currentColor">
                    <path fill-rule="evenodd" d="M5.293 7.293a1 1 0 011.414 0L10 10.586l3.293-3.293a1 1 0 111.414 1.414l-4 4a1 1 0 01-1.414 0l-4-4a1 1 0 010-1.414z" clip-rule="evenodd" />
                  </svg>
                </button>
                <div
                  id="preferred-time-listbox"
                  role="listbox"
                  aria-labelledby="preferred-time-label"
                  class="absolute top-full left-0 right-0 mt-1 py-1 bg-white dark:bg-[#0a0a0a] border border-gray-300 dark:border-gray-800 rounded-[4px] shadow-lg z-50 opacity-0 invisible transition-all duration-200"
                >
                  <div role="option" data-value="Mon-Fri Morning" class="px-3 py-2.5 text-gray-900 dark:text-white cursor-pointer hover:bg-gray-100 dark:hover:bg-gray-800 transition-colors">Mon-Fri Morning</div>
                  <div role="option" data-value="Mon-Fri Afternoon" class="px-3 py-2.5 text-gray-900 dark:text-white cursor-pointer hover:bg-gray-100 dark:hover:bg-gray-800 transition-colors">Mon-Fri Afternoon</div>
                  <div role="option" data-value="Mon-Fri Evening" class="px-3 py-2.5 text-gray-900 dark:text-white cursor-pointer hover:bg-gray-100 dark:hover:bg-gray-800 transition-colors">Mon-Fri Evening</div>
                </div>
              </div>
            </div>

            <!-- Preferred Contact Method -->
            <div class="space-y-6">

              <div>
                <p class="text-sm text-gray-500 dark:text-gray-400 mb-3 font-medium">Preferred contact method:</p>
                <div class="flex flex-wrap gap-6">
                  <label class="flex items-center cursor-pointer group">
                    <input type="checkbox" name="contact-method" value="Email" class="sr-only peer" />
                    <div class="w-5 h-5 border border-gray-400 dark:border-gray-600 rounded mr-3 flex items-center justify-center peer-checked:border-black dark:peer-checked:border-white peer-checked:bg-black dark:peer-checked:bg-white transition-colors">
                      <svg class="w-3 h-3 text-white dark:text-black opacity-0 peer-checked:opacity-100" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="3" d="M5 13l4 4L19 7" />
                      </svg>
                    </div>
                    <span class="text-gray-600 dark:text-gray-300 group-hover:text-black dark:group-hover:text-white transition-colors">Email</span>
                  </label>

                  <label class="flex items-center cursor-pointer group">
                    <input type="checkbox" name="contact-method" value="Phone" class="sr-only peer" />
                    <div class="w-5 h-5 border border-gray-400 dark:border-gray-600 rounded mr-3 flex items-center justify-center peer-checked:border-black dark:peer-checked:border-white peer-checked:bg-black dark:peer-checked:bg-white transition-colors">
                      <svg class="w-3 h-3 text-white dark:text-black opacity-0 peer-checked:opacity-100" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="3" d="M5 13l4 4L19 7" />
                      </svg>
                    </div>
                    <span class="text-gray-600 dark:text-gray-300 group-hover:text-black dark:group-hover:text-white transition-colors">Phone Call</span>
                  </label>

                  <label class="flex items-center cursor-pointer group">
                    <input type="checkbox" name="contact-method" value="WhatsApp" class="sr-only peer" />
                    <div class="w-5 h-5 border border-gray-400 dark:border-gray-600 rounded mr-3 flex items-center justify-center peer-checked:border-black dark:peer-checked:border-white peer-checked:bg-black dark:peer-checked:bg-white transition-colors">
                      <svg class="w-3 h-3 text-white dark:text-black opacity-0 peer-checked:opacity-100" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="3" d="M5 13l4 4L19 7" />
                      </svg>
                    </div>
                    <span class="text-gray-600 dark:text-gray-300 group-hover:text-black dark:group-hover:text-white transition-colors">WhatsApp</span>
                  </label>
                </div>
              </div>
            </div>

            <button 
              type="submit" 
              class="w-full bg-black dark:bg-white text-white dark:text-black font-bold py-3.5 px-8 rounded-full cursor-pointer hover:bg-gray-800 dark:hover:bg-gray-200 transition-colors mt-4"
            >
              Request Discovery Call
            </button>
            
            <p class="text-xs text-gray-500 dark:text-gray-400 text-center mt-3">
              We respond within 24 hours to schedule your call.
            </p>
          </form>
        </div>
      </div>

      <!-- BOTTOM CTA SECTION -->
      <div class="text-center">
        <p class="text-gray-600 dark:text-gray-400 text-lg">
          Can't find a time? <a href="https://wa.me/27814623628" target="_blank" rel="noopener noreferrer" class="text-black dark:text-white underline hover:text-gray-600 dark:hover:text-gray-300 transition-colors">Message us on WhatsApp</a>
        </p>
      </div>

    </div>
  </main>

  <Footer />

  <script>
    document.addEventListener('DOMContentLoaded', () => {
      // Pre-select service interest based on URL query parameter
      const urlParams = new URLSearchParams(window.location.search);
      const interest = urlParams.get('interest');
      if (interest) {
        const radio = document.querySelector(`input[name="interest"][value="${interest}"]`);
        if (radio) {
          (radio as HTMLInputElement).checked = true;
        }
      }

      // Custom dropdown for preferred time
      const trigger = document.getElementById('preferred-time-trigger');
      const listbox = document.getElementById('preferred-time-listbox');
      const hiddenInput = document.getElementById('preferred-time-input') as HTMLInputElement;
      const labelEl = document.getElementById('preferred-time-label');

      if (trigger && listbox && hiddenInput && labelEl) {
        const options = listbox.querySelectorAll('[role="option"]');

        const open = () => {
          listbox.classList.remove('opacity-0', 'invisible');
          trigger?.setAttribute('aria-expanded', 'true');
          (trigger?.querySelector('svg') as SVGElement)?.classList.add('rotate-180');
        };

        const close = () => {
          listbox.classList.add('opacity-0', 'invisible');
          trigger?.setAttribute('aria-expanded', 'false');
          (trigger?.querySelector('svg') as SVGElement)?.classList.remove('rotate-180');
        };

        const select = (value: string, label: string) => {
          hiddenInput.value = value;
          labelEl.textContent = label;
          labelEl.classList.remove('text-gray-500', 'dark:text-gray-400');
          labelEl.classList.add('text-gray-900', 'dark:text-white');
          close();
        };

        trigger.addEventListener('click', (e) => {
          e.preventDefault();
          const isOpen = !listbox.classList.contains('invisible');
          if (isOpen) close();
          else open();
        });

        options.forEach((opt) => {
          opt.addEventListener('click', () => {
            const value = opt.getAttribute('data-value');
            const text = opt.textContent?.trim();
            if (value && text) select(value, text);
          });
        });

        document.addEventListener('click', (e) => {
          const container = document.getElementById('preferred-time-dropdown');
          if (container && !container.contains(e.target as Node)) close();
        });

        listbox.addEventListener('keydown', (e) => {
          if (e.key === 'Escape') close();
        });
      }

      // Form Validation
      const form = document.getElementById('discovery-form') as HTMLFormElement;
      const nameInput = document.getElementById('name') as HTMLInputElement;
      const emailInput = document.getElementById('email') as HTMLInputElement;
      const nameError = document.getElementById('name-error');
      const emailError = document.getElementById('email-error');

      if (form) {
        form.addEventListener('submit', (e) => {
          let isValid = true;

          // Validate Name
          if (!nameInput.value.trim()) {
            isValid = false;
            nameError?.classList.remove('hidden');
            nameInput.classList.add('border-red-500');
          } else {
            nameError?.classList.add('hidden');
            nameInput.classList.remove('border-red-500');
          }

          // Validate Email
          const emailRegex = /^[^\s@]+@[^\s@]+\.[^\s@]+$/;
          if (!emailInput.value.trim() || !emailRegex.test(emailInput.value.trim())) {
            isValid = false;
            emailError?.classList.remove('hidden');
            emailInput.classList.add('border-red-500');
          } else {
            emailError?.classList.add('hidden');
            emailInput.classList.remove('border-red-500');
          }

          if (!isValid) {
            e.preventDefault();
          }
        });

        // Real-time validation
        nameInput.addEventListener('input', () => {
          if (nameInput.value.trim()) {
            nameError?.classList.add('hidden');
            nameInput.classList.remove('border-red-500');
          }
        });

        emailInput.addEventListener('input', () => {
          const emailRegex = /^[^\s@]+@[^\s@]+\.[^\s@]+$/;
          if (emailRegex.test(emailInput.value.trim())) {
            emailError?.classList.add('hidden');
            emailInput.classList.remove('border-red-500');
          }
        });
      }
    });
  </script>
</Layout>
