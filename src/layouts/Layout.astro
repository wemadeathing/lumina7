---
export interface Props {
  title: string;
  description?: string;
  image?: string;
  canonical?: string;
  useGlobalTopGradient?: boolean;
}

const { 
  title, 
  description = "Cape Town design studio specialising in brand identity, websites, print and signage for South African businesses. Fast turnaround. Fixed quotes. B-BBEE Level 1.",
  image = "/assets/og/lumina7-og-default.png",
  canonical,
  useGlobalTopGradient = false
} = Astro.props;

const canonicalURL = canonical || new URL(Astro.url.pathname, Astro.site);
const socialImage = new URL(image, Astro.site);

// Import design tokens
import '../styles/design-tokens.css';
import Header from '../components/Header.astro';
import WhatsAppFloating from '../components/WhatsAppFloating.astro';
import { ClientRouter } from 'astro:transitions';
---

<!doctype html>
<html lang="en">
  <head>
    <!-- Prevent FOUC - must run before page renders -->
    <script is:inline>
      (function() {
        const storedTheme = localStorage.getItem('color-theme');
        const systemPrefersDark = window.matchMedia('(prefers-color-scheme: dark)').matches;
        
        if (storedTheme === 'dark' || (!storedTheme && systemPrefersDark)) {
          document.documentElement.classList.add('dark');
        } else {
          document.documentElement.classList.remove('dark');
        }
      })();
    </script>
    
    <meta charset="UTF-8" />
    <meta name="description" content={description} />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="icon" type="image/png" href="/assets/favicon/L7-favicon-blk.png" />
    
    <!-- Preconnect for performance -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Instrument+Sans:ital,wght@0,400..700;1,400..700&family=Archivo:wdth,wght@62..125,100..900&display=swap" rel="stylesheet">
    <meta name="generator" content={Astro.generator} />
    
    <!-- Canonical URL -->
    <link rel="canonical" href={canonicalURL} />
    
    <!-- Open Graph / Facebook -->
    <meta property="og:type" content="website" />
    <meta property="og:site_name" content="Lumina7" />
    <meta property="og:locale" content="en_ZA" />
    <meta property="og:url" content={canonicalURL} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={socialImage} />
    
    <!-- Twitter -->
    <meta property="twitter:card" content="summary_large_image" />
    <meta property="twitter:url" content={canonicalURL} />
    <meta property="twitter:title" content={title} />
    <meta property="twitter:description" content={description} />
    <meta property="twitter:image" content={socialImage} />
    
    <!-- Additional SEO -->
    <meta name="robots" content="index, follow, max-image-preview:large, max-snippet:-1, max-video-preview:-1" />
    <meta name="author" content="Lumina7" />
    
    <!-- Sitemap reference -->
    <link rel="sitemap" type="application/xml" href="/sitemap-index.xml" />
    
    <!-- Structured Data - Organization / ProfessionalService -->
    <script type="application/ld+json">
      {JSON.stringify({
        "@context": "https://schema.org",
        "@type": ["Organization", "ProfessionalService"],
        "name": "Lumina7",
        "url": "https://lumina7.co.za",
        "logo": "https://lumina7.co.za/assets/logos/L7-logo-blk.png",
        "image": "https://lumina7.co.za/assets/logos/L7-logo-blk.png",
        "description": "Cape Town design studio specialising in brand identity, websites, print and signage for South African businesses.",
        "priceRange": "R800 - R12,000+",
        "address": {
          "@type": "PostalAddress",
          "addressLocality": "Cape Town",
          "addressRegion": "Western Cape",
          "addressCountry": "ZA"
        },
        "geo": {
          "@type": "GeoCoordinates",
          "latitude": -33.9249,
          "longitude": 18.4241
        },
        "areaServed": {
          "@type": "Country",
          "name": "South Africa"
        },
        "contactPoint": {
          "@type": "ContactPoint",
          "telephone": "+27-81-462-3628",
          "contactType": "Customer Service",
          "availableLanguage": ["en"],
          "areaServed": "ZA"
        },
        "sameAs": [
          "https://wa.me/27814623628"
        ],
        "founder": {
          "@type": "Person",
          "name": "Naasif Salaam"
        },
        "hasOfferCatalog": {
          "@type": "OfferCatalog",
          "name": "Design Services",
          "itemListElement": [
            {
              "@type": "Offer",
              "itemOffered": {
                "@type": "Service",
                "name": "Brand Identity",
                "description": "Logo, colour, typography and brand guidelines."
              },
              "priceSpecification": {
                "@type": "PriceSpecification",
                "price": "5000",
                "priceCurrency": "ZAR",
                "minPrice": "5000"
              }
            },
            {
              "@type": "Offer",
              "itemOffered": {
                "@type": "Service",
                "name": "Print & Marketing Materials",
                "description": "Flyers, brochures, business cards, menus."
              },
              "priceSpecification": {
                "@type": "PriceSpecification",
                "price": "800",
                "priceCurrency": "ZAR",
                "minPrice": "800"
              }
            },
            {
              "@type": "Offer",
              "itemOffered": {
                "@type": "Service",
                "name": "Signage & Installations",
                "description": "Shopfront signage, banners, vehicle branding."
              },
              "priceSpecification": {
                "@type": "PriceSpecification",
                "price": "1500",
                "priceCurrency": "ZAR",
                "minPrice": "1500"
              }
            },
            {
              "@type": "Offer",
              "itemOffered": {
                "@type": "Service",
                "name": "Website Design & Development",
                "description": "Professional websites that look great and load fast."
              },
              "priceSpecification": {
                "@type": "PriceSpecification",
                "price": "8000",
                "priceCurrency": "ZAR",
                "minPrice": "8000"
              }
            },
            {
              "@type": "Offer",
              "itemOffered": {
                "@type": "Service",
                "name": "Social Media & Digital Assets",
                "description": "Profile graphics, post templates, digital ads."
              },
              "priceSpecification": {
                "@type": "PriceSpecification",
                "price": "1200",
                "priceCurrency": "ZAR",
                "minPrice": "1200"
              }
            }
          ]
        }
      })}
    </script>
    
    <title>{title}</title>
    
    <!-- Named slot for additional head content (e.g., structured data) -->
    <slot name="head" />
    <ClientRouter />
  </head>
  <body class="min-h-screen antialiased transition-colors duration-300 bg-primary text-primary">
    <Header />
    <div id="main-content" class="relative isolate bg-primary">
      {useGlobalTopGradient && (
        <div class="absolute top-0 left-1/2 -translate-x-1/2 w-[120%] h-64 bg-gradient-to-r from-spot/25 via-spot/10 to-transparent blur-[100px] opacity-100 dark:opacity-40 -z-10 pointer-events-none" aria-hidden="true"></div>
      )}
      <slot />
    </div>
    <WhatsAppFloating />
    <script>
      import { startMicroInteractions } from '../scripts/micro-interactions.ts';

      startMicroInteractions();
    </script>
  </body>
  <style is:global>
    * {
      font-family: 'Instrument Sans', -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif;
    }
    
    body {
      font-family: 'Instrument Sans', -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif;
      line-height: 1.6;
    }
    
    html, body {
      overflow-x: hidden;
    }

    html {
      scroll-padding-top: 80px;
      scroll-behavior: smooth;
    }

    /* "The Proof" typography - Archivo display (signage lettering) over Instrument Sans body */
    h1, h2, h3, h4, h5, h6 {
      font-family: 'Archivo', 'Instrument Sans', -apple-system, sans-serif;
      font-stretch: 112%;
      font-weight: 660;
      line-height: 1.15;
      letter-spacing: -0.02em;
    }

    ::selection {
      background: #FFB200;
      color: #16140F;
    }

    .text-display {
      font-family: 'Archivo', 'Instrument Sans', sans-serif;
      font-stretch: 112%;
      font-size: clamp(2.5rem, 8vw, 6rem);
      font-weight: 740;
      line-height: 0.95;
      letter-spacing: -0.03em;
    }

    .text-large {
      font-family: 'Archivo', 'Instrument Sans', sans-serif;
      font-stretch: 112%;
      font-size: clamp(1.5rem, 4vw, 2.5rem);
      font-weight: 660;
      line-height: 1.1;
      letter-spacing: -0.02em;
    }

    /* Hide scrollbar for horizontal scroll */
    .scrollbar-hide {
      -ms-overflow-style: none;  /* Internet Explorer 10+ */
      scrollbar-width: none;  /* Firefox */
    }
    .scrollbar-hide::-webkit-scrollbar { 
      display: none;  /* Safari and Chrome */
    }

    /* Smooth link hover effects - only apply to links without specific transitions */
    a:not([class*="transition"]) {
      transition: color 0.2s ease-in-out;
    }

    ::view-transition-old(root),
    ::view-transition-new(root) {
      animation-duration: 180ms;
      animation-timing-function: cubic-bezier(0.22, 1, 0.36, 1);
    }

    @media (prefers-reduced-motion: reduce) {
      ::view-transition-old(root),
      ::view-transition-new(root) {
        animation-duration: 1ms;
      }
    }
  </style>

  <script>
    function syncThemeClass(root = document.documentElement) {
      const storedTheme = localStorage.getItem('color-theme');
      const systemPrefersDark = window.matchMedia('(prefers-color-scheme: dark)').matches;

      if (storedTheme === 'dark' || (!storedTheme && systemPrefersDark)) {
        root.classList.add('dark');
      } else {
        root.classList.remove('dark');
      }
    }

    document.addEventListener('astro:before-swap', function(event) {
      syncThemeClass(event.newDocument.documentElement);
    });

    // Smooth scroll for anchor links
    document.addEventListener('click', function(e) {
      if (!e.target) return;
      const link = (e.target as HTMLElement).closest('a[href^="#"]');
      if (!link) return;
      
      e.preventDefault();
      const href = link.getAttribute('href');
      if (!href) return;
      const target = document.querySelector(href);
      if (target) {
        target.scrollIntoView({
          behavior: 'smooth',
          block: 'start'
        });
      }
    });
  </script>
</html>
