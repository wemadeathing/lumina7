---
import Section from './Section.astro';
---
<Section variant="dark" padding="lg" id="contact">
  <div class="max-w-4xl mx-auto">
    <!-- CTA Content -->
    <div class="space-y-10">
      <div>
        <h2 class="text-3xl md:text-4xl lg:text-5xl font-semibold text-white leading-tight">
          Let's work together <span class="text-gray-400">to build a brand that supports your business growth.</span>
        </h2>
      </div>
      
      <div class="border-t border-gray-700 pt-10">
        <div class="flex items-end justify-between">
          <div class="text-caption text-gray-500 leading-tight">
            WE RESPOND WITHIN<br />24 HOURS
          </div>
          
          <a 
            href="/contact" 
            class="inline-flex items-center text-white text-xl font-medium hover:text-gray-300 group"
          >
            <span>Let's talk</span>
            <span class="ml-4 group-hover:translate-x-1 transition-transform">→</span>
          </a>
        </div>
      </div>
    </div>
  </div>
</Section>
