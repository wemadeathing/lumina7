---
import Section from './Section.astro';
---
<Section variant="default" padding="lg" id="contact" class="border-t border-gray-200 dark:border-neutral-900 !pb-24 md:!pb-32">
  <div class="w-full">
    <div class="w-full flex flex-col lg:flex-row lg:items-start lg:justify-between gap-10">
      <div>
        <h2 class="text-heading-2 md:text-heading-1 text-gray-900 dark:text-white leading-tight max-w-2xl">
          Ready to get started? Let's talk.
        </h2>
      </div>
      <div class="border-t lg:border-t-0 lg:border-l border-gray-200 dark:border-neutral-800 pt-10 lg:pt-0 lg:pl-10 w-full lg:max-w-md">
        <p class="text-sm text-gray-600 dark:text-gray-400 leading-relaxed mb-6">
          Tell us what you need and we'll come back to you within a few hours — usually on WhatsApp. No long forms, no commitment.
        </p>
        <a
          href="https://wa.me/27814623628?text=Hi%2C%20I%27d%20like%20to%20discuss%20a%20project%20with%20Lumina7"
          target="_blank"
          rel="noopener noreferrer"
          class="inline-flex items-center gap-2 px-6 py-3 text-sm font-medium text-white bg-gray-900 dark:bg-white dark:text-gray-900 rounded-full hover:bg-gray-800 dark:hover:bg-gray-100 transition-colors duration-200 group"
        >
          <span>WhatsApp Us</span>
          <span class="group-hover:translate-x-0.5 transition-transform duration-200">+</span>
        </a>
      </div>
    </div>
  </div>
</Section>
