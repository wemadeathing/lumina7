---
export interface Props {
  testimonials: Array<{
    quote: string;
    name: string;
    business: string;
  }>;
  heading?: string;
}

const {
  testimonials,
  heading = 'What our clients say'
} = Astro.props;
---

<section class="pt-16 pb-6 md:pt-20 md:pb-10 px-6 lg:px-8 bg-primary transition-colors duration-300" data-testimonials>
  <div class="max-w-7xl mx-auto">
    <p class="text-caption text-tertiary mb-3">Testimonials</p>
    <h2 class="text-heading-2 text-primary mb-7 md:mb-8">{heading}</h2>

    <div class="relative min-h-[16rem] md:min-h-[18rem] lg:min-h-[19rem] overflow-hidden">
      {testimonials.map((testimonial, index) => (
        <article
          class={`testimonial-slide absolute inset-0 transition-opacity duration-500 ease-out ${index === 0 ? 'opacity-100' : 'opacity-0 pointer-events-none'}`}
          role="tabpanel"
          aria-hidden={index === 0 ? 'false' : 'true'}
          data-testimonial-slide
          data-index={index}
        >
          <div>
            <p class="text-[1.4rem] leading-[1.14] sm:text-[1.65rem] md:text-[2.25rem] md:leading-[1.1] font-medium text-primary tracking-tight max-w-5xl">
              “{testimonial.quote}”
            </p>
          </div>

          <div class="mt-7 md:mt-8 flex flex-col sm:flex-row sm:items-end sm:justify-between gap-3">
            <div>
              <p class="text-caption text-primary tracking-[0.16em] uppercase">{testimonial.name}</p>
              <p class="text-caption text-tertiary tracking-[0.14em] uppercase mt-1">Client</p>
            </div>
            <div class="flex items-center gap-5 md:gap-6 shrink-0">
              {testimonials.map((_, i) => (
                <button
                  class="testimonial-step group text-left rounded-[4px] focus-visible:outline-none focus-visible:ring-1 focus-visible:ring-primary/60"
                  type="button"
                  aria-label={`Show testimonial ${i + 1}`}
                  data-testimonial-step
                  data-index={i}
                  aria-current={i === 0 ? 'true' : 'false'}
                >
                  <span class={`inline-block text-caption transition-colors ${i === 0 ? 'text-primary' : 'text-tertiary group-hover:text-secondary'}`}>
                    {(i + 1).toString().padStart(2, '0')}
                  </span>
                </button>
              ))}
            </div>
          </div>
        </article>
      ))}
    </div>

    <div class="mt-4 md:mt-5">
      <div class="relative h-[2px] w-full max-w-2xl overflow-hidden rounded-full bg-primary/20">
        <span
          class="testimonial-progress absolute inset-y-0 left-0 w-0 rounded-full bg-primary"
          data-testimonial-progress
        ></span>
      </div>
    </div>
  </div>
</section>

<script>
  import { initTestimonials } from './testimonials';

  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', initTestimonials);
  } else {
    initTestimonials();
  }

  document.addEventListener('astro:page-load', initTestimonials);
</script>
