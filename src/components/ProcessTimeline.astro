---
export interface Props {
  eyebrow?: string;
  title: string;
  subtitle?: string;
  steps: Array<{
    label: string;
    title: string;
    description: string;
  }>;
  autoRotateMs?: number;
  class?: string;
}

const {
  eyebrow = 'Let’s get started',
  title,
  subtitle,
  steps,
  autoRotateMs = 6500,
  class: className = ''
} = Astro.props;
---

<section
  class={`py-20 px-4 sm:px-6 lg:px-8 bg-primary transition-colors duration-300 ${className}`}
  data-process-timeline
  data-interval={autoRotateMs}
>
  <div class="max-w-7xl mx-auto">
    <p class="text-caption text-secondary mb-3">{eyebrow}</p>
    <h2 class="text-heading-2 text-primary max-w-5xl">{title}</h2>
    {subtitle && (
      <p class="text-body-lg text-secondary mt-4 max-w-3xl">{subtitle}</p>
    )}

    <div class="mt-12 grid md:grid-cols-3 gap-10 md:gap-12">
      {steps.map((step, index) => (
        <article
          class={`process-step transition-opacity duration-300 ${index === 0 ? 'opacity-100' : 'opacity-35'}`}
          data-process-step
          data-index={index}
        >
          <p class="text-caption text-secondary mb-6">{step.label}</p>
          <h3 class={`process-step-title text-heading-3 mb-4 ${index === 0 ? 'text-primary' : 'text-secondary'}`}>{step.title}</h3>
          <p class="text-body text-secondary">{step.description}</p>
        </article>
      ))}
    </div>

    <div class="mt-12">
      <div class="relative h-11">
        <div class="absolute left-0 right-0 top-1/2 h-px bg-gray-200 dark:bg-neutral-800 -translate-y-1/2"></div>
        <div class="relative flex items-center justify-between">
          {steps.map((step, index) => (
            <button
              type="button"
              class={`process-marker min-h-[44px] min-w-[44px] h-11 w-11 border border-primary bg-secondary flex items-center justify-center transition-all duration-300 focus:outline-none focus-visible:ring-1 focus-visible:ring-white/80 focus-visible:border-white/80 ${
                index === 0 ? 'ring-1 ring-white/80 border-white/80' : 'hover:bg-tertiary'
              }`}
              aria-label={`Show ${step.label}`}
              data-process-marker
              data-index={index}
            >
              <span class={`process-marker-dot h-1.5 w-1.5 rounded-full bg-primary transition-opacity duration-300 ${index === 0 ? 'opacity-100' : 'opacity-0'}`}></span>
            </button>
          ))}
        </div>
      </div>
    </div>
  </div>
</section>

<script>
  import { initProcessTimelines } from './process-timeline';

  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', initProcessTimelines);
  } else {
    initProcessTimelines();
  }
  document.addEventListener('astro:page-load', initProcessTimelines);
</script>
