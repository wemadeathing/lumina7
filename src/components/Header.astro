---
import ThemeToggle from './ThemeToggle.astro';
import AccentPicker from './AccentPicker.astro';
---

<!-- Logo top left - gloss blur bar (visible on load, backdrop shows on scroll) -->
<header id="main-header" class="fixed top-0 left-0 right-0 z-50 h-20 pointer-events-none transition-all duration-300 bg-transparent">
  <div id="header-backdrop" class="absolute inset-0 opacity-0 invisible pointer-events-none transition-opacity duration-300" aria-hidden="true"></div>
  <div class="absolute top-0 left-0 right-0 h-20 flex items-center justify-between px-6 lg:px-8 pointer-events-none">
    <a href="/" class="header-logo pointer-events-auto flex items-center hover:opacity-80 transition-opacity relative z-10">
      <img src="/assets/logos/L7-logo-blk.svg" alt="Lumina7" class="header-logo-light h-7 dark:hidden" />
      <img src="/assets/logos/L7-logo-wht.png" alt="Lumina7" class="header-logo-dark h-7 hidden dark:block" />
    </a>
    <div class="flex items-center gap-8 pointer-events-auto relative z-10">
      <nav class="hidden lg:flex items-center gap-7" aria-label="Primary">
        <a href="/work" class="label-mono text-gray-600 dark:text-neutral-400 hover:text-gray-900 dark:hover:text-white transition-colors duration-300 py-2 focus-visible:outline-none focus-visible:ring-1 focus-visible:ring-primary/60 rounded-[4px]">Work</a>
        <a href="/services" class="label-mono text-gray-600 dark:text-neutral-400 hover:text-gray-900 dark:hover:text-white transition-colors duration-300 py-2 focus-visible:outline-none focus-visible:ring-1 focus-visible:ring-primary/60 rounded-[4px]">Services</a>
        <a href="/about" class="label-mono text-gray-600 dark:text-neutral-400 hover:text-gray-900 dark:hover:text-white transition-colors duration-300 py-2 focus-visible:outline-none focus-visible:ring-1 focus-visible:ring-primary/60 rounded-[4px]">About</a>
        <a href="/contact" class="label-mono text-gray-600 dark:text-neutral-400 hover:text-gray-900 dark:hover:text-white transition-colors duration-300 py-2 focus-visible:outline-none focus-visible:ring-1 focus-visible:ring-primary/60 rounded-[4px]">Contact</a>
      </nav>
      <div class="hidden lg:block"><ThemeToggle /></div>
      <div class="hidden lg:block"><AccentPicker /></div>
      <a href="https://wa.me/27814623628?text=Hi%2C%20I%27d%20like%20to%20enquire%20about%20your%20design%20services" target="_blank" rel="noopener noreferrer" class="header-cta px-5 py-2.5 text-sm font-semibold rounded-full transition-all duration-300 focus-visible:outline-none focus-visible:ring-1 focus-visible:ring-primary/60 focus-visible:ring-offset-2 inline-flex items-center gap-2" data-event="whatsapp_click" data-event-source="header">
        WhatsApp Us
        <span aria-hidden="true">→</span>
      </a>
    </div>
  </div>
</header>

<!-- Bottom floating menu -->
<nav
  id="floating-nav"
  class="floating-nav-surface lg:hidden fixed bottom-4 sm:bottom-6 left-1/2 -translate-x-1/2 z-50 flex items-center justify-center gap-0.5 w-[calc(100vw-2rem)] max-w-md px-2 sm:px-3 py-2 sm:py-2.5 rounded-full backdrop-blur-xl border overflow-hidden"
  aria-label="Main navigation"
>
  <a href="/" class="nav-link px-3 py-3 min-h-[44px] flex items-center rounded-full text-sm font-medium text-gray-700 dark:text-gray-300 hover:text-gray-900 dark:hover:text-white hover:bg-gray-100/80 dark:hover:bg-gray-800/80 transition-colors duration-300 focus-visible:outline-none focus-visible:ring-1 focus-visible:ring-primary/60 whitespace-nowrap" data-path="/">
    Home
  </a>
  <a href="/about" class="nav-link px-3 py-3 min-h-[44px] flex items-center rounded-full text-sm font-medium text-gray-700 dark:text-gray-300 hover:text-gray-900 dark:hover:text-white hover:bg-gray-100/80 dark:hover:bg-gray-800/80 transition-colors duration-300 focus-visible:outline-none focus-visible:ring-1 focus-visible:ring-primary/60 whitespace-nowrap" data-path="/about">
    About
  </a>
  <a href="/services" class="nav-link px-3 py-3 min-h-[44px] flex items-center rounded-full text-sm font-medium text-gray-700 dark:text-gray-300 hover:text-gray-900 dark:hover:text-white hover:bg-gray-100/80 dark:hover:bg-gray-800/80 transition-colors duration-300 focus-visible:outline-none focus-visible:ring-1 focus-visible:ring-primary/60 whitespace-nowrap" data-path="/services">
    Services
  </a>
  <a href="/work" class="nav-link px-3 py-3 min-h-[44px] flex items-center rounded-full text-sm font-medium text-gray-700 dark:text-gray-300 hover:text-gray-900 dark:hover:text-white hover:bg-gray-100/80 dark:hover:bg-gray-800/80 transition-colors duration-300 focus-visible:outline-none focus-visible:ring-1 focus-visible:ring-primary/60 whitespace-nowrap" data-path="/work">
    Work
  </a>
  <button
    id="nav-more-btn"
    class="ml-1 flex items-center justify-center min-h-[44px] min-w-[44px] rounded-full bg-gray-100 dark:bg-gray-800 text-gray-600 dark:text-gray-400 hover:bg-gray-200 dark:hover:bg-gray-700 transition-all duration-300"
    aria-label="More options"
    aria-controls="nav-more-panel"
  >
    <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 5v.01M12 12v.01M12 19v.01M12 6a1 1 0 110-2 1 1 0 010 2zm0 7a1 1 0 110-2 1 1 0 010 2zm0 7a1 1 0 110-2 1 1 0 010 2z"></path>
    </svg>
  </button>
</nav>

<!-- More dropdown (contact, theme) -->
<div
  id="nav-more-panel"
  class="lg:hidden fixed bottom-20 left-1/2 -translate-x-1/2 z-50 w-64 p-4 rounded-2xl bg-white dark:bg-gray-900 border border-gray-200 dark:border-gray-700 shadow-xl opacity-0 invisible translate-y-2 transition-all duration-300 ease-out"
>
  <div class="space-y-3">
    <a href="mailto:hello@lumina7.co.za" class="block text-sm text-gray-700 dark:text-gray-300 hover:text-gray-900 dark:hover:text-white py-2 px-1 -mx-1 rounded-[4px] transition-colors duration-300 focus-visible:outline-none focus-visible:ring-1 focus-visible:ring-primary/60 focus-visible:ring-offset-2" data-event="email_click" data-event-source="header_more">hello@lumina7.co.za</a>
    <a href="https://wa.me/27814623628" target="_blank" rel="noopener noreferrer" class="block text-sm text-gray-700 dark:text-gray-300 hover:text-gray-900 dark:hover:text-white py-2 px-1 -mx-1 rounded-[4px] transition-colors duration-300 focus-visible:outline-none focus-visible:ring-1 focus-visible:ring-primary/60 focus-visible:ring-offset-2" data-event="whatsapp_click" data-event-source="header_more">+27 81 462 3628</a>
    <a href="/contact" class="block text-sm text-gray-700 dark:text-gray-300 hover:text-gray-900 dark:hover:text-white py-2 px-1 -mx-1 rounded-[4px] transition-colors duration-300 focus-visible:outline-none focus-visible:ring-1 focus-visible:ring-primary/60 focus-visible:ring-offset-2" data-event="contact_form_link_click" data-event-source="header_more">Contact form</a>
    <div class="pt-2 border-t border-gray-200 dark:border-gray-700 flex items-center justify-between">
      <span class="text-sm text-gray-600 dark:text-gray-400">Theme</span>
      <ThemeToggle />
    </div>
    <div class="pt-2 border-t border-gray-200 dark:border-gray-700 space-y-2">
      <span class="text-sm text-gray-600 dark:text-gray-400">Accent</span>
      <AccentPicker variant="inline" />
    </div>
    <a href="https://wa.me/27814623628?text=Hi%2C%20I%27d%20like%20to%20enquire%20about%20your%20design%20services" target="_blank" rel="noopener noreferrer" class="block text-sm font-medium text-gray-900 dark:text-white py-2 px-1 -mx-1 rounded-[4px] hover:opacity-80 transition-opacity duration-300 focus-visible:outline-none focus-visible:ring-1 focus-visible:ring-primary/60 focus-visible:ring-offset-2" data-event="whatsapp_click" data-event-source="header_more">WhatsApp Us</a>
  </div>
</div>

<div id="nav-more-backdrop" class="fixed inset-0 z-40 opacity-0 invisible transition-opacity" aria-hidden="true"></div>

<!-- Spacer for fixed header -->
<div class="h-20" aria-hidden="true"></div>

<script>
  function initFloatingNav() {
    const pathname = window.location.pathname;
    const navLinks = document.querySelectorAll('.nav-link');
    const moreBtn = document.getElementById('nav-more-btn');
    const morePanel = document.getElementById('nav-more-panel');
    const backdrop = document.getElementById('nav-more-backdrop');

    // Set active state (white pill) on current page
    function isActive(linkPath: string | null) {
      if (linkPath === '/') return pathname === '/' || pathname === '';
      return pathname === linkPath || pathname.startsWith(linkPath + '/');
    }
    navLinks.forEach(link => {
      link.classList.remove('bg-gray-200/90', 'text-gray-900', 'dark:bg-gray-700/60', 'dark:text-gray-100');
      link.classList.add('text-gray-700', 'dark:text-gray-300', 'hover:bg-gray-100/80', 'dark:hover:bg-gray-800/80');
      const linkPath = link.getAttribute('data-path');
      if (linkPath && isActive(linkPath)) {
        link.classList.add('bg-gray-200/90', 'text-gray-900', 'dark:bg-gray-700/60', 'dark:text-gray-100');
        link.classList.remove('text-gray-700', 'dark:text-gray-300', 'hover:bg-gray-100/80', 'dark:hover:bg-gray-800/80');
      }
    });

    // More button toggle
    if (moreBtn && morePanel && backdrop) {
      function closeMorePanel() {
        morePanel.classList.add('opacity-0', 'invisible', 'translate-y-2');
        backdrop.classList.add('opacity-0', 'invisible');
        moreBtn.setAttribute('aria-expanded', 'false');
      }
      moreBtn.setAttribute('aria-expanded', morePanel.classList.contains('invisible') ? 'false' : 'true');
      if ((moreBtn as HTMLElement).dataset.navBound === 'true') return;
      (moreBtn as HTMLElement).dataset.navBound = 'true';
      moreBtn.addEventListener('click', (e) => {
        e.stopPropagation();
        const isOpen = !morePanel.classList.contains('invisible');
        if (isOpen) {
          closeMorePanel();
        } else {
          morePanel.classList.remove('opacity-0', 'invisible', 'translate-y-2');
          backdrop.classList.remove('opacity-0', 'invisible');
          backdrop.classList.add('opacity-100', 'visible');
          moreBtn.setAttribute('aria-expanded', 'true');
        }
      });
      backdrop.addEventListener('click', closeMorePanel);
      document.addEventListener('keydown', (event) => {
        if (event.key === 'Escape') closeMorePanel();
      });
    }
  }

  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', initFloatingNav);
  } else {
    initFloatingNav();
  }
  document.addEventListener('astro:page-load', initFloatingNav);

  // Top header backdrop: no background on load, glass effect on scroll
  const headerBackdrop = document.getElementById('header-backdrop');
  if (headerBackdrop) {
    function updateHeaderScroll() {
      const el = document.getElementById('header-backdrop');
      if (el) {
        if (window.scrollY > 20) {
          el.classList.remove('opacity-0', 'invisible');
          el.classList.add('opacity-100', 'visible', 'header-backdrop-visible');
        } else {
          el.classList.add('opacity-0', 'invisible');
          el.classList.remove('opacity-100', 'visible', 'header-backdrop-visible');
        }
      }
    }
    window.addEventListener('scroll', updateHeaderScroll);
    updateHeaderScroll();
  }
</script>

<style>
  .floating-nav-surface {
    background: color-mix(in srgb, var(--bg-elevated) 88%, transparent);
    border-color: color-mix(in srgb, var(--text-primary) 10%, transparent);
    box-shadow: 0 10px 30px rgb(18 18 20 / 0.12);
  }

  :global(html.dark) .floating-nav-surface {
    background: color-mix(in srgb, var(--bg-elevated) 96%, transparent);
    border-color: color-mix(in srgb, var(--text-primary) 18%, transparent);
    box-shadow: 0 14px 40px rgb(0 0 0 / 0.48);
  }

  /* Top header CTA - accent surface (colour or gradient) in both modes */
  .header-cta {
    background: var(--spot-surface);
    color: var(--color-spot-ink);
  }
  .header-cta:hover {
    filter: brightness(0.96);
    transform: translateY(-1px);
    box-shadow: 0 4px 16px color-mix(in srgb, var(--color-spot) 35%, transparent);
  }

  /* Top header - transparent on load in both modes; backdrop shows on scroll only */
  :global(#main-header) {
    background-color: transparent !important;
    background-image: none !important;
  }

  /* Top header backdrop - light: glass on scroll; dark: stronger glass on scroll */
  #header-backdrop {
    background: transparent;
  }
  #header-backdrop.header-backdrop-visible {
    background: rgba(255, 255, 255, 0.4);
    backdrop-filter: blur(20px) saturate(180%);
    -webkit-backdrop-filter: blur(20px) saturate(180%);
  }
  :global(html.dark) #header-backdrop.header-backdrop-visible {
    background: rgba(0, 0, 0, 0.5);
    backdrop-filter: blur(20px) saturate(120%);
    -webkit-backdrop-filter: blur(20px) saturate(120%);
  }
</style>
