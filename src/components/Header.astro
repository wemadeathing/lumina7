---
import ThemeToggle from './ThemeToggle.astro';
---

<!-- Logo top left - gloss blur bar (visible on load, backdrop shows on scroll) -->
<header id="main-header" class="fixed top-0 left-0 right-0 z-50 h-20 pointer-events-none transition-all duration-300 bg-transparent">
  <div id="header-backdrop" class="absolute inset-0 opacity-0 invisible pointer-events-none transition-opacity duration-300" aria-hidden="true"></div>
  <div class="absolute top-0 left-0 right-0 h-20 flex items-center justify-between px-6 lg:px-8 pointer-events-none">
    <a href="/" class="header-logo pointer-events-auto flex items-center hover:opacity-80 transition-opacity relative z-10">
      <img src="/assets/logos/L7-logo-blk.svg" alt="Lumina7" class="header-logo-light h-7 dark:hidden" />
      <img src="/assets/logos/L7-logo-wht.png" alt="Lumina7" class="header-logo-dark h-7 hidden dark:block" />
    </a>
    <div class="flex items-center gap-3 pointer-events-auto relative z-10">
      <a href="https://wa.me/27814623628?text=Hi%2C%20I%27d%20like%20to%20enquire%20about%20your%20design%20services" target="_blank" rel="noopener noreferrer" class="hidden md:inline-flex items-center gap-2 text-sm font-medium text-gray-700 dark:text-gray-300 hover:text-gray-900 dark:hover:text-white px-2 py-1 rounded-[4px] transition-colors duration-300 focus-visible:outline-none focus-visible:ring-1 focus-visible:ring-primary/60 focus-visible:ring-offset-2">
        WhatsApp Us
        <span aria-hidden="true">→</span>
      </a>
      <a href="/book" class="header-cta px-5 py-2.5 text-sm font-medium rounded-full transition-colors duration-300 focus-visible:outline-none focus-visible:ring-1 focus-visible:ring-primary/60 focus-visible:ring-offset-2">
        Book a call
      </a>
    </div>
  </div>
</header>

<!-- Bottom floating menu -->
<nav
  id="floating-nav"
  class="fixed bottom-4 sm:bottom-6 left-1/2 -translate-x-1/2 z-50 flex items-center gap-0.5 px-3 sm:px-4 py-2 sm:py-2.5 rounded-full bg-white/80 dark:bg-gray-900/80 backdrop-blur-xl border border-gray-200/80 dark:border-gray-700/50 shadow-sm max-w-[calc(100vw-2rem)] overflow-x-auto scrollbar-hide"
  aria-label="Main navigation"
>
  <a href="/" class="nav-link px-4 py-2 rounded-full text-sm font-medium text-gray-700 dark:text-gray-300 hover:text-gray-900 dark:hover:text-white hover:bg-gray-100/80 dark:hover:bg-gray-800/80 transition-colors duration-300 focus-visible:outline-none focus-visible:ring-1 focus-visible:ring-primary/60 whitespace-nowrap" data-path="/">
    Home
  </a>
  <a href="/about" class="nav-link px-4 py-2 rounded-full text-sm font-medium text-gray-700 dark:text-gray-300 hover:text-gray-900 dark:hover:text-white hover:bg-gray-100/80 dark:hover:bg-gray-800/80 transition-colors duration-300 focus-visible:outline-none focus-visible:ring-1 focus-visible:ring-primary/60 whitespace-nowrap" data-path="/about">
    About
  </a>
  <a href="/services" class="nav-link px-4 py-2 rounded-full text-sm font-medium text-gray-700 dark:text-gray-300 hover:text-gray-900 dark:hover:text-white hover:bg-gray-100/80 dark:hover:bg-gray-800/80 transition-colors duration-300 focus-visible:outline-none focus-visible:ring-1 focus-visible:ring-primary/60 whitespace-nowrap" data-path="/services">
    Services
  </a>
  <a href="/work" class="nav-link px-4 py-2 rounded-full text-sm font-medium text-gray-700 dark:text-gray-300 hover:text-gray-900 dark:hover:text-white hover:bg-gray-100/80 dark:hover:bg-gray-800/80 transition-colors duration-300 focus-visible:outline-none focus-visible:ring-1 focus-visible:ring-primary/60 whitespace-nowrap" data-path="/work">
    Work
  </a>
  <button
    id="nav-more-btn"
    class="ml-2 flex items-center justify-center w-9 h-9 rounded-full bg-gray-100 dark:bg-gray-800 text-gray-600 dark:text-gray-400 hover:bg-gray-200 dark:hover:bg-gray-700 transition-all duration-300"
    aria-label="More options"
  >
    <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 5v.01M12 12v.01M12 19v.01M12 6a1 1 0 110-2 1 1 0 010 2zm0 7a1 1 0 110-2 1 1 0 010 2zm0 7a1 1 0 110-2 1 1 0 010 2z"></path>
    </svg>
  </button>
</nav>

<!-- More dropdown (contact, theme, book) -->
<div
  id="nav-more-panel"
  class="fixed bottom-20 left-1/2 -translate-x-1/2 z-50 w-64 p-4 rounded-2xl bg-white dark:bg-gray-900 border border-gray-200 dark:border-gray-700 shadow-xl opacity-0 invisible translate-y-2 transition-all duration-300 ease-out"
>
  <div class="space-y-3">
    <a href="mailto:hello@lumina7.co.za" class="block text-sm text-gray-700 dark:text-gray-300 hover:text-gray-900 dark:hover:text-white py-2 px-1 -mx-1 rounded-[4px] transition-colors duration-300 focus-visible:outline-none focus-visible:ring-1 focus-visible:ring-primary/60 focus-visible:ring-offset-2">hello@lumina7.co.za</a>
    <a href="https://wa.me/27814623628" target="_blank" rel="noopener noreferrer" class="block text-sm text-gray-700 dark:text-gray-300 hover:text-gray-900 dark:hover:text-white py-2 px-1 -mx-1 rounded-[4px] transition-colors duration-300 focus-visible:outline-none focus-visible:ring-1 focus-visible:ring-primary/60 focus-visible:ring-offset-2">+27 81 462 3628</a>
    <div class="pt-2 border-t border-gray-200 dark:border-gray-700 flex items-center justify-between">
      <span class="text-sm text-gray-600 dark:text-gray-400">Theme</span>
      <ThemeToggle />
    </div>
    <a href="/book" class="block text-sm font-medium text-gray-900 dark:text-white py-2 px-1 -mx-1 rounded-[4px] hover:opacity-80 transition-opacity duration-300 focus-visible:outline-none focus-visible:ring-1 focus-visible:ring-primary/60 focus-visible:ring-offset-2">Book a call</a>
  </div>
</div>

<div id="nav-more-backdrop" class="fixed inset-0 z-40 opacity-0 invisible transition-opacity" aria-hidden="true"></div>

<!-- Spacer for fixed header -->
<div class="h-20" aria-hidden="true"></div>

<script>
  function initFloatingNav() {
    const pathname = window.location.pathname;
    const navLinks = document.querySelectorAll('.nav-link');
    const moreBtn = document.getElementById('nav-more-btn');
    const morePanel = document.getElementById('nav-more-panel');
    const backdrop = document.getElementById('nav-more-backdrop');

    // Set active state (white pill) on current page
    function isActive(linkPath: string | null) {
      if (linkPath === '/') return pathname === '/' || pathname === '';
      return pathname === linkPath || pathname.startsWith(linkPath + '/');
    }
    navLinks.forEach(link => {
      const linkPath = link.getAttribute('data-path');
      if (linkPath && isActive(linkPath)) {
        link.classList.add('bg-gray-200/90', 'text-gray-900', 'dark:bg-gray-700/60', 'dark:text-gray-100');
        link.classList.remove('text-gray-700', 'dark:text-gray-300', 'hover:bg-gray-100/80', 'dark:hover:bg-gray-800/80');
      }
    });

    // More button toggle
    if (moreBtn && morePanel && backdrop) {
      moreBtn.addEventListener('click', (e) => {
        e.stopPropagation();
        const isOpen = !morePanel.classList.contains('invisible');
        if (isOpen) {
          morePanel.classList.add('opacity-0', 'invisible', 'translate-y-2');
          backdrop.classList.add('opacity-0', 'invisible');
        } else {
          morePanel.classList.remove('opacity-0', 'invisible', 'translate-y-2');
          backdrop.classList.remove('opacity-0', 'invisible');
          backdrop.classList.add('opacity-100', 'visible');
        }
      });
      backdrop.addEventListener('click', () => {
        morePanel.classList.add('opacity-0', 'invisible', 'translate-y-2');
        backdrop.classList.add('opacity-0', 'invisible');
      });
    }
  }

  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', initFloatingNav);
  } else {
    initFloatingNav();
  }
  document.addEventListener('astro:page-load', initFloatingNav);

  // Top header backdrop: no background on load, glass effect on scroll
  const headerBackdrop = document.getElementById('header-backdrop');
  if (headerBackdrop) {
    function updateHeaderScroll() {
      const el = document.getElementById('header-backdrop');
      if (el) {
        if (window.scrollY > 20) {
          el.classList.remove('opacity-0', 'invisible');
          el.classList.add('opacity-100', 'visible', 'header-backdrop-visible');
        } else {
          el.classList.add('opacity-0', 'invisible');
          el.classList.remove('opacity-100', 'visible', 'header-backdrop-visible');
        }
      }
    }
    window.addEventListener('scroll', updateHeaderScroll);
    updateHeaderScroll();
  }
</script>

<style>
  /* Top header content - explicit light/dark mode colors for visibility */
  .header-cta {
    background-color: #18181b;
    color: white;
  }
  .header-cta:hover {
    background-color: #27272a;
  }
  :global(.dark) .header-cta {
    background-color: white;
    color: #18181b;
  }
  :global(.dark) .header-cta:hover {
    background-color: #f4f4f5;
  }

  /* Top header - transparent on load in both modes; backdrop shows on scroll only */
  :global(#main-header) {
    background-color: transparent !important;
    background-image: none !important;
  }

  /* Top header backdrop - light: glass on scroll; dark: stronger glass on scroll */
  #header-backdrop {
    background: transparent;
  }
  #header-backdrop.header-backdrop-visible {
    background: rgba(255, 255, 255, 0.4);
    backdrop-filter: blur(20px) saturate(180%);
    -webkit-backdrop-filter: blur(20px) saturate(180%);
  }
  :global(html.dark) #header-backdrop.header-backdrop-visible {
    background: rgba(0, 0, 0, 0.5);
    backdrop-filter: blur(20px) saturate(120%);
    -webkit-backdrop-filter: blur(20px) saturate(120%);
  }
</style>
