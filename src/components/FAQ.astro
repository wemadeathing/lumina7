---
export interface Props {
  faqItems: Array<{
    number: string;
    question: string;
    answer: string;
  }>;
  heading?: string;
}

const { faqItems, heading = "Frequently Asked Questions" } = Astro.props;
---

<!-- FAQ Section - Becklyn minimal -->
<section class="pt-8 pb-16 md:pt-12 md:pb-20 px-6 lg:px-8 bg-primary transition-colors duration-300" id="faq">
  <div class="max-w-7xl mx-auto">
    <h2 class="text-heading-2 text-primary mb-12">
      {heading}
    </h2>
    <div class="space-y-0">
      {faqItems.map((item, index) => (
        <div class="faq-item border-b border-primary last:border-b-0" data-faq={index}>
          <button class="faq-trigger w-full text-left py-6 group rounded-[4px] focus-visible:outline-none focus-visible:ring-1 focus-visible:ring-primary/60">
            <div class="flex items-center justify-between gap-8">
              <h3 class="text-lg font-medium text-primary group-hover:text-secondary transition-colors">
                {item.question}
              </h3>
              <span class="faq-icon text-xl text-tertiary group-hover:text-primary transition-all duration-300 transform origin-center">+</span>
            </div>
          </button>
          
          <div class="faq-content overflow-hidden max-h-0 transition-all duration-500 ease-in-out">
            <div class="pb-6 opacity-0 transition-opacity duration-300 delay-150">
              <p class="text-lg text-secondary leading-relaxed">
                {item.answer}
              </p>
            </div>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>

<style>
  /* Active state for open FAQ items */
  .faq-item.is-open .faq-content {
    max-height: 500px;
  }

  .faq-item.is-open .faq-content > div {
    opacity: 1;
  }

  .faq-item.is-open .faq-icon {
    transform: rotate(45deg);
  }
</style>

<script>
  function initFAQ() {
    const faqTriggers = document.querySelectorAll<HTMLButtonElement>('.faq-trigger');
    faqTriggers.forEach(trigger => {
      trigger.addEventListener('click', () => {
        const faqItem = trigger.closest('.faq-item');
        const content = faqItem?.querySelector<HTMLElement>('.faq-content');
        if (!faqItem || !content) return;
        const isOpen = faqItem.classList.contains('is-open');
        faqTriggers.forEach(otherTrigger => {
          if (otherTrigger !== trigger) {
            const otherItem = otherTrigger.closest('.faq-item');
            const otherContent = otherItem?.querySelector<HTMLElement>('.faq-content');
            if (otherItem?.classList.contains('is-open') && otherContent) {
              otherItem.classList.remove('is-open');
              otherContent.style.maxHeight = '0';
              setTimeout(() => {
                const innerDiv = otherContent.querySelector<HTMLElement>('div');
                if (innerDiv) innerDiv.style.opacity = '0';
              }, 50);
            }
          }
        });
        if (isOpen) {
          faqItem.classList.remove('is-open');
          content.style.maxHeight = '0';
          setTimeout(() => {
            const innerDiv = content.querySelector<HTMLElement>('div');
            if (innerDiv) innerDiv.style.opacity = '0';
          }, 50);
        } else {
          faqItem.classList.add('is-open');
          const contentHeight = content.scrollHeight;
          content.style.maxHeight = contentHeight + 'px';
          setTimeout(() => {
            const innerDiv = content.querySelector<HTMLElement>('div');
            if (innerDiv) innerDiv.style.opacity = '1';
          }, 150);
        }
      });
    });
  }
  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', initFAQ);
  } else {
    initFAQ();
  }
  document.addEventListener('astro:page-load', initFAQ);
</script>
