---
const timelineSteps = [
  {
    step: "01",
    time: "Week 1, Day 1-2",
    title: "Kickoff & Discovery",
    description: "Deep dive call, strategy alignment, and brief collection. We define success before we start design."
  },
  {
    step: "02",
    time: "Week 1, Day 3-4",
    title: "Initial Concepts",
    description: "Rapid exploration. We deliver 2 distinct design directions for you to review and choose from."
  },
  {
    step: "03",
    time: "Week 1, Day 5",
    title: "Direction Lock",
    description: "Feedback session and selection. We consolidate your feedback to lock in the winning direction."
  },
  {
    step: "04",
    time: "Week 2, Day 1-3",
    title: "Production",
    description: "Build out, iteration, and polish. We expand the chosen direction into a complete system or site."
  },
  {
    step: "05",
    time: "Week 2, Day 4-5",
    title: "Launch",
    description: "Final files, handover training, and go live. We ensure you have everything needed to scale."
  }
];
---

<section class="py-20 bg-white dark:bg-[#0a0a0a] transition-colors duration-300 overflow-hidden">
  <div class="max-w-7xl mx-auto px-6 lg:px-8 text-left">
    <div class="mb-12 flex flex-col md:flex-row md:items-end justify-between gap-6">
      <div>
        <h2 class="text-3xl md:text-4xl lg:text-5xl font-medium text-gray-900 dark:text-white mb-4">
          How it works
        </h2>
        <p class="text-gray-600 dark:text-gray-400 text-lg max-w-2xl">
          A structured 2-week sprint designed to move fast without breaking things.
        </p>
      </div>
      
      <!-- Scroll Controls (Desktop) -->
      <div class="hidden md:flex gap-4">
        <button id="timeline-scroll-left" class="p-3 rounded-full border border-gray-200 dark:border-gray-800 text-gray-900 dark:text-white hover:bg-gray-100 dark:hover:bg-gray-800 transition-colors" aria-label="Scroll left">
          <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7" />
          </svg>
        </button>
        <button id="timeline-scroll-right" class="p-3 rounded-full border border-gray-200 dark:border-gray-800 text-gray-900 dark:text-white hover:bg-gray-100 dark:hover:bg-gray-800 transition-colors" aria-label="Scroll right">
          <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" />
          </svg>
        </button>
      </div>
    </div>

    <!-- Timeline Scroller -->
    <div 
      id="timeline-gallery" 
      class="flex overflow-x-auto gap-6 pb-8 snap-x snap-mandatory scrollbar-hide -mx-6 px-6 lg:-ml-8 lg:pl-8 lg:mr-[calc(50%-50vw)] lg:pr-8"
    >
      {timelineSteps.map((step, index) => (
        <div class="flex-none w-[85vw] sm:w-[350px] snap-center">
          <div class="h-full bg-white/60 dark:bg-gray-900/30 backdrop-blur-md border border-gray-200 dark:border-gray-800 p-8 rounded-2xl relative group hover:border-gray-300 dark:hover:border-gray-700 transition-colors duration-300">
            <!-- Connector Line (Desktop only, except last item) -->
            {index !== timelineSteps.length - 1 && (
              <div class="hidden lg:block absolute top-1/2 -right-3 w-6 h-[1px] bg-gray-200 dark:bg-gray-800 z-10"></div>
            )}
            
            <div class="text-[4rem] font-medium text-gray-300 dark:text-gray-600 mb-4 leading-none group-hover:text-gray-400 dark:group-hover:text-gray-500 transition-colors">
              {step.step}
            </div>
            
            <div class="mb-2">
              <span class="text-xs font-bold uppercase tracking-wider text-gray-500 dark:text-gray-500 bg-gray-100 dark:bg-gray-800 px-2 py-1 rounded-full">
                {step.time}
              </span>
            </div>
            
            <h3 class="text-xl font-medium text-gray-900 dark:text-white mb-3">
              {step.title}
            </h3>
            
            <p class="text-gray-600 dark:text-gray-400 text-sm leading-relaxed">
              {step.description}
            </p>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>

<script>
  const container = document.getElementById('timeline-gallery');
  const leftBtn = document.getElementById('timeline-scroll-left');
  const rightBtn = document.getElementById('timeline-scroll-right');

  if (container && leftBtn && rightBtn) {
    leftBtn.addEventListener('click', () => {
      container.scrollBy({ left: -350, behavior: 'smooth' });
    });

    rightBtn.addEventListener('click', () => {
      container.scrollBy({ left: 350, behavior: 'smooth' });
    });
  }
</script>
